{
	quest.00CB8D60E7831A57.quest_desc: ["Le catacombe sono enormi strutture sotterranee fatte di Depthrock Bricks. Potrebbero avere una parte che sporge dal terreno che puoi trovare. \\n\\nAll'interno dell'enorme labirinto si trovano &7Forgottens&r, forzieri nascosti e il boss: &aForgotten Guardian&r. \\n\\nSpero che tu sia preparato!"]
	quest.00CB8D60E7831A57.title: "Catacombs"
	quest.01B13BBB41BBB460.quest_desc: ["&cUtherium Armor&r ha le stesse statistiche dell'Armatura Netherite! \\n\\nSenza bisogno di un modello di forgiatura!"]
	quest.01B13BBB41BBB460.title: "&cUtherium&r Armor"
	quest.050D8480EE9D8E62.quest_desc: [
		"Le foreste di Wigglewood sono foreste come tutte le altre. \\n\\nSolo a questi alberi piace andare come vogliono."
		"{image:atm:textures/questpics/undergarden/undergarden_wiggle.png width:200 height:100 align:center}"
	]
	quest.050D8480EE9D8E62.title: "Wigglewood Forest"
	quest.06D13E319C26C949.quest_desc: [
		"La palude dei funghi sanguigni è la dimora dei giganteschi funghi sanguigni. \\n\\nIl sangue mi mette a disagio, quindi penso che farò una breve descrizione."
		"{image:atm:textures/questpics/undergarden/undergarden_blood.png width:200 height:100 align:center}"
	]
	quest.06D13E319C26C949.title: "Blood Mushroom Bog"
	quest.073BA8470EA37A00.quest_desc: [
		"Un altro Mare, solo che questo è molto più freddo."
		"{image:atm:textures/questpics/undergarden/undergarden_icey.png width:200 height:100 align:center}"
	]
	quest.073BA8470EA37A00.title: "Icy Sea"
	quest.08D9C809CF4062E8.quest_desc: ["Mangiateli crudi, arrostiteli, metteteli su uno stecco. \\n\\nCosa non puoi fare con Underbeans!"]
	quest.0A0A991BAC99092C.quest_desc: [
		"La palude dei funghi indaco è molto più piena della palude dei funghi sanguigni. \\n\\nOvviamente contiene funghi indaco ma anche mini alberi Smogstem e stagni di miscela virulenta. Mi chiedo cosa fa..."
		"{image:atm:textures/questpics/undergarden/undergarden_indigo.png width:200 height:100 align:center}"
	]
	quest.0A0A991BAC99092C.title: "Indigo Mushroom Bog"
	quest.0A1D6E233C0ECC8E.quest_desc: [
		"Gli &dNargoyles&r sono mob cattivi e ostili che si generano sottoterra. \\n\\nHanno 7 cuori e mezzo e cercheranno incessantemente di ucciderti. \\n\\nNon lasciano cadere nulla e servono solo da ostacolo per coloro che cercano di estrarre pacificamente. "
		"{image:atm:textures/questpics/undergarden/undergarden_nargoyle.png width:100 height:100 align:center}"
	]
	quest.0A1D6E233C0ECC8E.title: "&dNargoyle&r"
	quest.0C98503A2F20484D.quest_desc: [
		"Vicino a Frostfields potresti trovare Frosty Smogstem Forests. \\n\\nSono proprio come i Campi Gelati, solo con gli alberi Smogstem!"
		"{image:atm:textures/questpics/undergarden/undergarden_frostytrees.png width:200 height:100 align:center}"
	]
	quest.0C98503A2F20484D.title: "Foresta gelida di smogstem"
	quest.0D91A6B36BD2F526.quest_desc: ["Aggiorna il tuo &7Cloggrum Battleaxe&r per creare l'arma più potente che &2&lUndergarden&r possa offrire!"]
	quest.0D91A6B36BD2F526.title: "Arma definitiva!"
	quest.0FA77C28A57E06F1.quest_desc: ["I Funghi Velati possono essere trovati solo nella loro Palude. \\n\\nHanno cappucci marroni che, se c'è aria sotto, genereranno veli di funghi. Da qui il nome!"]
	quest.1054168AFD8520D4.quest_desc: [
		"Il &aForgotten Guardian&r è un enorme Golem realizzato con &aForgotten Ingots&r. \\n\\nPrenderà di mira il giocatore e farà tutto il necessario per ucciderlo. \\n\\nHanno 80 cuori e se riesci a ucciderli lasceranno cadere &aForgotten Nuggets&r."
		"{image:atm:textures/questpics/undergarden/undergarden_guardian.png width:100 height:200 align:center}"
	]
	quest.1054168AFD8520D4.title: "&aForgotten Guardian&r"
	quest.1190BB433EFA3945.quest_desc: ["La fionda è un'arma molto divertente aggiunta da &2&lUndergarden&r. Ha 4 munizioni che possono essere sparate: \\n\\nScintling Goo può essere sparato e quando colpisce un Mob gli darà l'effetto Gooey. \\n\\nLe rocce profonde sono solo normali proiettili. \\n\\nLe bacche vescicolari marce esploderanno all'impatto. \\n\\nE &eGronglets&r non fa alcun danno, fa solo rumore e viene colpito!"]
	quest.119242549BD21764.quest_desc: [
		"&eBrutes&r si genera in alcuni biomi e sono neutrali. \\n\\nSe colpito, tutti nell'area ti attaccheranno. Simile ai Lupi o ai Piglin Zombificati. \\n\\nAlla morte potrebbero perdere le zanne, che possono sostituire le ossa!"
		"{image:atm:textures/questpics/undergarden/undergarden_brute.png width:100 height:100 align:center}"
	]
	quest.119242549BD21764.title: "&eBrutes&r"
	quest.130577AD1A1A8222.quest_desc: ["&7Cloggrum&r ha statistiche un po' peggiori di Iron Armor, ma praticamente cresce sugli alberi, quindi penso che sia giusto. \\n\\nGli stivali aiutano anche a superare Scintling Goo!"]
	quest.130577AD1A1A8222.title: "&7Cloggrum&r Armor"
	quest.141681FE9E524FB0.quest_desc: [
		"Gli &7Forgottens&r sono guerrieri che si generano all'interno della struttura della catacomba. \\n\\nIndossano armature antiche e tengono strumenti di Cloggrum, che possono essere lasciati cadere alla morte. \\n\\nPrenderanno di mira e uccideranno anche &cRot Mobs&r."
		"{image:atm:textures/questpics/undergarden/undergarden_forgotten.png width:100 height:200 align:center}"
	]
	quest.141681FE9E524FB0.title: "&7Forgotten&r"
	quest.15A8F04BC10E619E.quest_desc: [
		"Alcune persone odiano esplorare molti biomi diversi per ottenere tutti i diversi alberelli. \\n\\nChiaramente lo sviluppatore &2&lUndergarden&r l'ha fatto, quindi ne ha collocati la maggior parte nella Foresta Fitta!"
		"{image:atm:textures/questpics/undergarden/undergarden_dense.png width:200 height:100 align:center}"
	]
	quest.15A8F04BC10E619E.title: "Dense Forest"
	quest.16A04B2FC3F0D902.quest_desc: ["Gli strumenti &7Cloggrum&r si comportano proprio come gli strumenti di ferro, semplicemente assomigliano più al fango che al ferro! \\n\\nLa Spada però infligge più danni di una Spada di Ferro."]
	quest.16A04B2FC3F0D902.title: "&7Cloggrum&r Tools"
	quest.17C2C8F64B4AE6EE.quest_desc: [
		"&2Dwellers&r sono le mucche di &2&lUndergarden&r. \\nSono passivi e alla morte rilasciano pelle e carne dell'abitante. \\n\\nGrazie a Dio non possono essere munti, non voglio il latte prodotto da questi &2Dwellers&r."
		"{image:atm:textures/questpics/undergarden/undergarden_dweller.png width:100 height:100 align:center}"
	]
	quest.17C2C8F64B4AE6EE.title: "&2Dweller&r"
	quest.1BAE1519E44E40CE.quest_desc: [
		"Immagina il Mar Antico. Ok, ora rimuovi tutte le alghe da esso e rimuovi tutti gli &bGwibs&r e &bGwiblings&r. \\n\\nQuesto è il Mar Morto per te!"
		"{image:atm:textures/questpics/undergarden/undergarden_dead.png width:200 height:100 align:center}"
	]
	quest.1BAE1519E44E40CE.title: "Dead Sea"
	quest.1C232674CD04024D.quest_desc: ["La dimensione &2&lUndergarden&r è piena di biomi diversi e disgustosi pieni di vegetazione, mob: amichevoli e ostili e, naturalmente, minerali e oggetti. \\n\\nSpero che tu sia pronto per combattere!"]
	quest.1C232674CD04024D.title: "Benvenuti nello &2&lUndergarden&r!"
	quest.1E13D7CE5A9EFF74.quest_desc: [
		"I Campi Gelati sono uno dei biomi freddi dello &2&lUndergarden&r. Puoi capire che fa freddo dagli enormi ghiacciai, dalla neve farinosa e dall'erba profonda congelata! \\n\\nAnche qui invece del solito sottosuolo di Depthrock troverai Shiverstone. \\n\\nShiverstone si comporta più come il Ghiaccio che come la vera Pietra. Beh, almeno quando ci si trova sopra!"
		"{image:atm:textures/questpics/undergarden/undergarden_frosty.png width:200 height:100 align:center}"
	]
	quest.1E13D7CE5A9EFF74.title: "Frostfields"
	quest.1E81B903137BB62A.quest_desc: ["Gli strumenti normali non saranno sufficienti, soprattutto quando si gestiscono i pericolosi Mob nello &2&lUndergarden&r. \\n\\nPossiamo creare il &7Cloggrum Shield&r che agisce come un normale scudo. \\n\\nMa dovremo procurarci il &7Battleaxe&r come drop raro da &7Forgottens&r."]
	quest.1E81B903137BB62A.title: "&7Cloggrum&r Weapons"
	quest.1FCF946B7BE3C0BD.quest_desc: ["Gli strumenti &cUtherium&r sono simili agli utensili diamantati ma le armi sono più efficaci di &cRot Mobs&r! \\n\\nUsi ciò che fanno per arrecargli più danni! Ci sono probabilmente una dozzina di riferimenti alla cultura pop che posso fare con questo, ma non riesco a pensare a nessuno..."]
	quest.1FCF946B7BE3C0BD.title: "&cUtheric&r Tools"
	quest.22739522F0D33D7B.quest_desc: ["I Gloomgourd si generano e coltivano come le zucche. \\n\\nInoltre, come le zucche, possono essere trasformate in torte o persino in Jack-O-Lanterns! \\n\\nA differenza delle zucche, possono essere trasformate in esplosivi..."]
	quest.24D38DA8E86DD897.quest_desc: [
		"Il più piccolo e il più debole degli &cRot Mobs&r. \\n\\nQuesti hanno 5 cuori. \\n\\nCome tutti gli &cRot Mobs&r prenderanno di mira &2Stoneborns&r e &7Forgottens&r e lasceranno cadere &cUtheric Shards&r."
		"{image:atm:textures/questpics/undergarden/undergarden_rotling.png width:100 height:100 align:center}"
	]
	quest.24D38DA8E86DD897.title: "&cRotling&r"
	quest.278D34BBC13356DF.quest_desc: [
		"Una palude viola! \\n\\nQuesti contengono funghi inchiostro e mix virulento ovunque!"
		"{image:atm:textures/questpics/undergarden/undergarden_ink.png width:200 height:100 align:center}"
	]
	quest.278D34BBC13356DF.title: "Ink Mushroom Bog"
	quest.2C5A7E4CD8B57E08.quest_desc: ["Gli alberi Grongle sono alti alberi simili alla giungla che si generano solo nei biomi Gronglegrowth! \\n\\nQuesti alberi sono anche il luogo in cui si generano &eGronglets&r."]
	quest.2E596B5A4EA2ABF4.quest_desc: [
		"Quello Smogvent si sta muovendo? No aspetta, è solo un &3S'Mog&r! Il cugino stretto dello &2Mog&r! \\n\\nSi comportano esattamente come &2Mogs&r, solo che potrebbero rilasciare Blue Mogmoss."
		"{image:atm:textures/questpics/undergarden/undergarden_smog.png width:100 height:100 align:center}"
	]
	quest.2E596B5A4EA2ABF4.title: "&3S'Mog&r"
	quest.30582B5FBED35FD1.quest_desc: ["&cUtherium&r può essere estratto o lasciato cadere da &cRot Mobs&r."]
	quest.30582B5FBED35FD1.title: "&cUtheric&r"
	quest.353AEEC116A5DEEF.quest_desc: [
		"I Mari Antichi sono mari spalancati nello &2&lUndergarden&r. \\n\\nIn qualche modo, anche con la quantità di sostanze inquinanti, l'acqua è sicura da bere. \\n\\nL'Acqua contiene anche &bGwibs&r e &bGwiblings&r. E non posso dimenticare Glitterkelp!"
		"{image:atm:textures/questpics/undergarden/undergarden_ancient.png width:200 height:100 align:center}"
	]
	quest.353AEEC116A5DEEF.title: "Ancient Sea"
	quest.36389696767EFB4E.quest_desc: [
		"L'Abisso sterile è, come suggerisce il nome, sterile... Non contiene altro che Mob e Ciottoli ostili. \\n\\nPersonalmente preferirei trovare Pebbles altrove..."
		"{image:atm:textures/questpics/undergarden/undergarden_barren.png width:200 height:100 align:center}"
	]
	quest.36389696767EFB4E.title: "Barren Abyss"
	quest.380D3212D1CBA593.quest_desc: [
		"Il &cRot Mob&r di medie dimensioni, il &cRotwalker&r. \\n\\nHanno 20 cuori. \\n\\nCome tutti gli &cRot Mobs&r prenderanno di mira &2Stoneborns&r e &7Forgottens&r e lasceranno cadere &cUtheric Shards&r."
		"{image:atm:textures/questpics/undergarden/undergarden_rotwalker.png width:100 height:200 align:center}"
	]
	quest.380D3212D1CBA593.title: "&cRotwalker&r"
	quest.3AF7446592D19FA6.quest_desc: ["&eRegalium&r è l'equivalente Smeraldo in &2&lUndergarden&r. \\n\\nNon può essere trasformato in armature o strumenti, ma può essere utilizzato per scambiare con &2Stoneborns&r altri oggetti."]
	quest.3AF7446592D19FA6.title: "&eRegalium&r"
	quest.4141EF8B8C316118.quest_desc: ["&7Cloggrum&r è il Ferro dello &2&lUndergarden&r. \\n\\nSi trova ovunque e viene utilizzato in una dozzina di ricette diverse. \\n\\nDiamine, anche alcuni mob lo lasciano cadere!"]
	quest.4141EF8B8C316118.title: "&7Cloggrum&r"
	quest.43A1BC20BB054A14.quest_desc: ["L'alga luccicante cresce nei mari antichi e ghiacciati. \\n\\nNon fanno altro che brillare e possono essere trasformati in torta!"]
	quest.43FD4AEBB9548E57.quest_desc: [
		"La Foresta Smogstem è un bioma vicino alle Paludi di Funghi Indaco. \\n\\nOvviamente è anche blu e contiene funghi indaco! Ha solo alberi Smogstem più grandi!"
		"{image:atm:textures/questpics/undergarden/undergarden_smogstem.png width:200 height:100 align:center}"
	]
	quest.43FD4AEBB9548E57.title: "Smogstem Forest"
	quest.4568C2F465EDB960.quest_desc: ["Droopfruit può generarsi praticamente in qualsiasi bioma, basta cercare! \\n\\nSi generano sul tetto della maggior parte dei biomi e crescono in modo simile alle Glowberries."]
	quest.46DCB235D3FEDA61.quest_desc: ["Similmente agli Iron Tools, tutti questi rallentano chiunque ne venga colpito. \\n\\nBeh a parte la Zappa, ma ti interessa davvero una semplice zappa?"]
	quest.46DCB235D3FEDA61.title: "&bFroststeel&r Tools"
	quest.49EB9FB2133E3219.quest_desc: ["L'Armatura Antica è ciò che indossa &7Forgottens&r ed è da lì che puoi ottenerla. \\n\\nNon ci sono però Stivali antichi, a quanto pare &7Forgottens&r non ha piedi."]
	quest.49EB9FB2133E3219.title: "Ancient Armor"
	quest.4C5CFA45D9B4F6D3.quest_desc: ["I funghi Indaco sono apparentemente i migliori amici di Smogstem e si genereranno principalmente con loro! "]
	quest.4C7E006502E30C20.quest_desc: ["Questa missione è stata creata da &6AllTheMods Staff&r o da un collaboratore della &2Community&r per l'uso in AllTheMods Modpacks.\\n\\nPoiché tutti i pacchetti &6AllTheMods&r sono concessi in licenza con &eAll Rights Reserved&r, questa missione non può essere utilizzata in nessun pacchetto pubblico non rilasciato dal &6AllTheMods Team&r senza permesso esplicito.\\n\\nQuesta missione è intenzionalmente nascosta, se vedi questo, sei in modalità di modifica."]
	quest.4D836B9D9E3B898F.quest_desc: [
		"&2Stoneborns&r sono il mix perfetto di Villagers e Iron Golem. \\n\\nPuoi commerciare con loro facendo clic con il pulsante destro del mouse. \\n\\nE combatteranno contro i mob ostili (o i giocatori che li colpiscono)."
		"{image:atm:textures/questpics/undergarden/undergarden_stoneborn.png width:100 height:150 align:center}"
	]
	quest.4D836B9D9E3B898F.title: "&2Stoneborn&r"
	quest.4E3D548E5D8D7D26.quest_desc: [
		"I Campi Dimenticati sono le Pianure degli &2&lUndergarden&r. \\n\\nNon hanno alberi ma hanno un sacco di rocce, fiori e mostri! \\n\\nNon generano &7Forgottens&r però, sì, mi spiace rovinare il tuo entusiasmo."
		"{image:atm:textures/questpics/undergarden/undergarden_field.png width:200 height:100 align:center}"
	]
	quest.4E3D548E5D8D7D26.title: "Forgotten Fields"
	quest.4F3B4990BE6C2A4A.quest_desc: [
		"Gli &7Scintlings&r sono piccole lumache innocenti che si trovano ovunque nello &2&lUndergarden&r. \\n\\nSi comportano come Golem di neve poiché lasciano una traccia ovunque camminino. Solo che questo è più appiccicoso... \\n\\nAlla morte rilasciano Scintling Goo, ma puoi semplicemente coltivarlo dalle loro tracce, quindi perché ucciderli!"
		"{image:atm:textures/questpics/undergarden/undergarden_scintling.png width:150 height:100 align:center}"
	]
	quest.4F3B4990BE6C2A4A.title: "&7Scintling&r"
	quest.4F5A2E2A5C7F4837.quest_desc: ["&aForgotten Ingots&r deve essere ottenuto attraverso le Catacombe; che si tratti di saccheggiare i forzieri o di uccidere il &aForgotten Guardian&r. \\n\\nAvrai bisogno anche di un modello di forgiatura che si trova nei bauli delle catacombe."]
	quest.4F5A2E2A5C7F4837.title: "&aForgotten&r"
	quest.511144EF336BFAF5.quest_desc: [
		"Le Smog Spires sono... sì, hai indovinato! Da dove viene tutto lo smog! Beh, non tutti, non possiamo screditare &2Mogs&r e &3S'mogs&r. \\n\\nQui troverai bacche vescicolari, terreno profondo grossolano e condotti di smog. Tuttavia non consiglierei di avvicinarsi a loro..."
		"{image:atm:textures/questpics/undergarden/undergarden_smogspires.png width:200 height:100 align:center}"
	]
	quest.511144EF336BFAF5.title: "Smog Spires"
	quest.51C59FDF0BD11FDF.quest_desc: ["Sono abbastanza sicuro che l'unica definizione di cosa sia un albero Wigglewood è che ha tronchi e foglie Wigglewood. Sembrano crescere in qualsiasi direzione, dimensione e forma. \\n\\nLi puoi trovare nelle foreste di Wigglewood e nelle fitte foreste. \\n\\nHanno foglie piuttosto rosa e tronchi marroni simili all'abete rosso!"]
	quest.51E2728C5E35A152.quest_desc: ["Il Froststeel si genera nei biomi ghiacciati: Campi di ghiaccio, Foreste di smogstem gelido e probabilmente Mari ghiacciati. \\n\\nSi genera a Shiverstone che sostituisce Depthrock in questi biomi. La Pietra Shiver si comporterà in modo simile al Ghiaccio poiché è scivolosa e ti rallenta un po'. \\n\\nPotresti anche trovare delle pepite nelle pance dei Muncher!"]
	quest.51E2728C5E35A152.title: "&bFroststeel&r"
	quest.53FDC6C536E50A1A.quest_desc: ["Gli &bGwiblings&r sono pesci amichevoli nei mari. \\n\\nSono più piccoli di &bGwibs&r e si comportano come Vanilla Fish!"]
	quest.53FDC6C536E50A1A.title: "&bGwibling&r"
	quest.5B4B5C148D63ACA1.quest_desc: [
		"Gli &aForgotten Minions&r non vengono generati come i normali Mob, devono essere creati. Vengono creati posizionando una Gloomgourd intagliata su un &aBlock of Forgotten Ingots&r. \\n\\nSi comportano in modo simile ai Golem di neve, non ti attaccheranno mai e spareranno invece ai Mob ostili. \\n\\nHanno 10 cuori e non lasciano nulla alla morte... ma perché dovresti ucciderli?"
		"{image:atm:textures/questpics/undergarden/undergarden_minion.png width:125 height:100 align:center}"
	]
	quest.5B4B5C148D63ACA1.title: "&aForgotten Minions&r"
	quest.5D229FA3A5F92954.quest_desc: [
		"Gli &4Munchers&r sono simili a tutti gli altri Mob ostili nello &2&lUndergarden&r, ma questi drop lo rendono molto più utile! \\n\\nIl Muncher può rilasciare &7Cloggrum&r e &bFroststeel Nuggets&r alla morte."
		"{image:atm:textures/questpics/undergarden/undergarden_muncher.png width:100 height:100 align:center}"
	]
	quest.5D229FA3A5F92954.title: "&4Muncher&r"
	quest.5E63C78CDC44FF95.quest_desc: ["Le bacche-blister marce non possono essere lanciate, ma se trasformate in bombe-blister sì! \\n\\nPuoi anche andare oltre e creare Boomgourd che si comporteranno come TNT che lancia Blisterberry ovunque."]
	quest.5E63C78CDC44FF95.title: "Esplosivi!!!"
	quest.5FCA6F5FE97780B7.quest_desc: [
		"&eGronglets&r sono tecnicamente Blocchi e non Mob. Ma li amo troppo per non includerli! \\n\\nSi generano sugli alberi Grongle ed emettono rumore e luce! Decisamente perfetto per la decorazione."
		"{image:atm:textures/questpics/undergarden/undergarden_gronglet.png width:100 height:100 align:center}"
	]
	quest.5FCA6F5FE97780B7.title: "&eGronglets&r"
	quest.6124C0E9E419694B.quest_desc: ["Aggiorna gli strumenti &7Cloggrum&r con &aForgotten Ingots&r e un modello di forgiatura. \\n\\nQuesti sono i migliori strumenti che puoi ottenere, sono già dotati di efficienza solo per i blocchi &2&lUndergarden&r. \\n\\nE la spada e l'ascia infliggeranno più danni a tutti i Mob &2&lUndergarden&r tranne &cRot Beast&r e &aForgotten Guardian&r!"]
	quest.6124C0E9E419694B.title: "&aForgotten&r Tools"
	quest.647A87E800C703C3.quest_desc: [
		"Il mio bioma preferito in assoluto! \\n\\nUna gigantesca giungla verde con enormi alberi a crescita grongle. \\n\\nSu quegli alberi puoi trovare &eGronglets&r!"
		"{image:atm:textures/questpics/undergarden/undergarden_grongle.png width:200 height:100 align:center}"
	]
	quest.647A87E800C703C3.title: "Gronglegrowth"
	quest.6751F2651063B3A5.quest_desc: ["I funghi sanguigni possono essere trovati nelle loro paludi. \\n\\nHanno la forma di querce scure e sono per lo più bianchi con solo alcuni blocchi con macchie di sangue su di essi!"]
	quest.67A2347534269528.quest_desc: [
		"&9Sploogies&r può generarsi raramente, ma quando lo fa è destinato a infastidirti. \\n\\nTi spareranno addosso (e faranno disgustosi rumori di risucchio) ma se li colpisci scapperanno; simile a un bambino Piglin. \\n\\nRilasciano solo ciottoli di roccia profonda alla morte."
		"{image:atm:textures/questpics/undergarden/undergarden_sploogie.png width:125 height:100 align:center}"
	]
	quest.67A2347534269528.title: "&9Sploogie&r"
	quest.6C4B93FE64BD418D.quest_desc: ["Arrivare allo &2&lUndergarden&r è simile ad arrivare allo &c&lThe Nether&r. Dovrai creare un portale. \\n\\nHa la stessa forma e dimensione dei portali Nether ma invece dell'ossidiana avrai bisogno di una varietà di mattoni di pietra. Mattoni di pietra, mattoni di pietra muschiosa o mattoni di ardesia profonda. \\n\\nUna volta formato, puoi attivarlo utilizzando il Catalizzatore su di esso. "]
	quest.6C4B93FE64BD418D.quest_subtitle: "Realizzare il Portale"
	quest.6C4B93FE64BD418D.title: "The Undergarden"
	quest.6D4FB6291CA8D1A6.quest_desc: ["Gli alberi Smogstem sono molto più spessi nella metà inferiore, simili agli alberi Baobab nella vita reale! \\n\\nHanno foglie blu con tronchi grigi. \\nPuoi trovarli in più biomi: foreste di smogstem, foreste fitte e persino nelle paludi di funghi indaco!"]
	quest.6F416275B6F6D8F0.quest_desc: ["Le bacche vescicolari si generano nelle guglie di smog. \\n\\nPoiché crescono in un'area così disgustosa, alcuni diventeranno marci. \\n\\nNon consiglio di mangiarli, magari possono servire ad altro!"]
	quest.70FD8856BFCD9AEE.quest_desc: [
		"Il più grande e pericoloso &cRot Mob&r. \\n\\nHanno 80 cuori, che penso si qualifichino come Miniboss. \\n\\nCome tutti gli &cRot Mobs&r prenderanno di mira &2Stoneborns&r e &7Forgottens&r e lasceranno cadere &cUtheric Shards&r."
		"{image:atm:textures/questpics/undergarden/undergarden_rotbeast.png width:100 height:100 align:center}"
	]
	quest.70FD8856BFCD9AEE.title: "&cRotbeast&r"
	quest.71E1454990DEC451.quest_desc: [
		"Gli &bGwibs&r sono versioni più grandi e più arrabbiate di &bGwiblings&r. \\n\\nNon hanno gocce né possono essere inseriti nei secchi. Tutto ciò che offrono è dolore!"
		"{image:atm:textures/questpics/undergarden/undergarden_gwib.png width:100 height:100 align:center}"
	]
	quest.71E1454990DEC451.title: "&bGwib&r"
	quest.739601B0C43B239B.quest_desc: ["Sì, possono fare la tintura nera!"]
	quest.744DBE831C120B2F.quest_desc: [
		"Quella roccia si sta muovendo? Oh aspetta, non è una roccia, è un &2Mog&r! \\n\\n&2Mogs&r può essere allevato insieme ai Ciottoli di Roccia Profonda e alla morte potresti rilasciare più Ciottoli o Mogmoss! \\n\\nMogmoss può essere utilizzato in molte ricette diverse!"
		"{image:atm:textures/questpics/undergarden/undergarden_mog.png width:100 height:100 align:center}"
	]
	quest.744DBE831C120B2F.title: "&2Mog&r"
	quest.7617737FC179EA1A.quest_desc: ["L'armatura &bFroststeel&r è leggermente peggiore dell'armatura diamante ma offre anche una grande resistenza al contraccolpo. \\n\\nDà anche un debuff alla velocità, sembra che non ci muoviamo molto!"]
	quest.7617737FC179EA1A.title: "&bFroststeel&r Armor"
	quest.76CDC18D7A208512.quest_desc: ["Nello &2&lUndergarden&r, &cRot Mobs&r può infettarti con &cUtherium&r. A dosi più basse, questa infezione decadrà nel tempo. A dosi sufficientemente elevate, non decade e dovrà essere curato con &3Rogdorium&r, che si trova solo nelle profondità delle regioni Dreadrock. Puoi consumarlo o infonderlo nella tua armatura per scongiurare questa infezione. Ti darò anche degli &3Rogdorium&r in regalo!"]
	quest.76CDC18D7A208512.title: "Warning"
	quest.79C652E3FCB88550.quest_desc: [
		"&5Gloompers&r sono tecnicamente Passivi ma hanno un meccanismo di difesa contro di te quindi li considero Neutrali! \\n\\nQuando vengono colpiti, rilasceranno un effetto simile a una pozione persistente. \\n\\nAlla morte lasceranno cadere le gambe (che sono molto gustose) e forse il cuoio. \\n\\nPossono anche essere incrociati con i Gloomgourd!"
		"{image:atm:textures/questpics/undergarden/undergarden_gloomper.png width:100 height:100 align:center}"
	]
	quest.79C652E3FCB88550.title: "&5Gloomper&r"
	quest.7E3DA4168D352B42.quest_desc: [
		"Prometto che questo è l'ultimo Mushroom Bog! \\nQuesti funghi sembrano abbastanza normali, ma il loro trucco è ciò che deriva da loro! \\n\\nI Veli! Sicuramente un utile blocco decorativo."
		"{image:atm:textures/questpics/undergarden/undergarden_veil.png width:200 height:100 align:center}"
	]
	quest.7E3DA4168D352B42.title: "Veil Mushroom Bog"
	task.2116DA966E4C7711.title: "Understanding Utheric Infections"
	task.39194D9CDF673768.title: "TuttiIDirittiRiservati"
	task.4AA225E5056787B8.title: "TuttiIDirittiRiservati"
}
