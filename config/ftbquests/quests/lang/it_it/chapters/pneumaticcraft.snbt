{
	quest.00075A5F9AC120ED.quest_desc: ["Questo eliminerà gli oggetti dalla cassa di input."]
	quest.00075A5F9AC120ED.quest_subtitle: "Always Required"
	quest.002163B909070CF8.quest_desc: [
		"Ti permette di vedere i dettagli su alcuni blocks/fluid, anche attraverso i muri.\\n"
		"{image:atm:textures/questpics/pneumaticcraft/block_tracker.png width:150 height:150 align:center}"
	]
	quest.002163B909070CF8.quest_subtitle: "Max: 1"
	quest.00D7BCC68D971A53.quest_desc: ["Le creature viventi nelle vicinanze verranno automaticamente tracciate, anche attraverso i muri. Se è un mob aggressivo riceverai un avviso quando ti prende di mira."]
	quest.00D7BCC68D971A53.quest_subtitle: "Max: 1"
	quest.02643BAD1AE747C6.quest_desc: ["Il &3Advanced Liquid Compressor&r funziona allo stesso modo del compressore liquido, solo molto meglio!"]
	quest.04BE9F63E6003475.quest_desc: ["&3LPG&r può essere utilizzato per produrre plastica fusa."]
	quest.04BE9F63E6003475.quest_subtitle: "Quello di cui abbiamo bisogno"
	quest.04BE9F63E6003475.title: "LPG"
	quest.0672462DA3599484.quest_subtitle: "512,000mb"
	quest.09BA45CBBFB4AE26.quest_desc: ["La fase successiva di questa mod richiede la configurazione di &3Assembly Lines&r. Il componente principale di un &3Assembly Line&r è il &3Assembly Controller&r.\\n\\nÈ qui che andrà la pressione."]
	quest.09BA45CBBFB4AE26.quest_subtitle: "Always Required"
	quest.0A912B2E2BE34920.quest_desc: [
		"Sebbene sia possibile trovare petrolio greggio in superficie, la perforazione è un ottimo modo per ottenere una grande quantità di petrolio. Per prima cosa usa un &3Seismic Sensor&r finché non trovi il petrolio sotto di te, quindi usa il tuo &3Gas Lift&r pieno di tubi di perforazione per perforare il petrolio. (Ciò richiede pressione per funzionare).\\n"
		"{image:pneumaticcraft:textures/patchouli/oil_pumping.png width:200 height:200 align:right fit:true}"
	]
	quest.0A912B2E2BE34920.quest_subtitle: "Perforazione per il petrolio"
	quest.0AEAEA976ED0C470.quest_desc: ["Il &3Charging Station&r viene utilizzato per caricare vari strumenti e gadget nello &aPneumaticCraft&r utilizzando la pressione."]
	quest.0AEAEA976ED0C470.quest_subtitle: "Dov'è il cavo?"
	quest.0CC48C2AA553A314.quest_desc: ["&3Drill Bits&r può essere utilizzato in un martello pneumatico pneumatico."]
	quest.0D2F5CC96269F9E3.quest_desc: ["Il passaggio successivo nella realizzazione di PCB prevede l'utilizzo dello &3Etching Tank&r con acido etching. Richiede calore per funzionare."]
	quest.0D2F5CC96269F9E3.quest_subtitle: "È l'ora dell'incisione!"
	quest.0D31CD79BE6CC8D2.quest_desc: ["Perché il pane normale non ha bisogno del lievito?"]
	quest.0D31CD79BE6CC8D2.quest_subtitle: "Il lievito dei tuoi problemi"
	quest.0D31CD79BE6CC8D2.title: "Yeast"
	quest.0D5015B8FF482D0A.quest_desc: [
		"Dovremo ordinare alcune cose da &3Amadron&r utilizzando &3Amadron Tablet&r per continuare la progressione. Per usarlo, fai clic con il tasto destro del mouse su un baule e un serbatoio di liquidi, metti la tua valuta in un contenitore collegato (Smeraldi, ecc.) e ordina qualcosa. Vedrai un Amadrone scendere per prendere i tuoi soldi e un altro Amadrone venire a consegnare ciò che hai ordinato."
		""
		"{image:atm:textures/questpics/pneumaticcraft/amadron_drone.png width:300 height:150 align:center}"
	]
	quest.0D5015B8FF482D0A.quest_subtitle: "Mi chiedo se hanno la consegna in 1 giorno?"
	quest.0D5015B8FF482D0A.title: "Amadron"
	quest.0D50BDEFA0319EA1.quest_desc: ["Questo lascerà cadere il prodotto finito nella cassa di uscita."]
	quest.0D50BDEFA0319EA1.quest_subtitle: "Always Required"
	quest.0D9560C8E247F9E7.quest_desc: ["Fai clic con il pulsante destro del mouse da qualche parte e sarai in grado di ritrovare la strada del ritorno. Se sei abbastanza vicino e hai un percorso diretto, apparirà un percorso."]
	quest.0D9560C8E247F9E7.quest_subtitle: "Max: 1"
	quest.0E65BE9460B74000.quest_desc: [
		"I Logistic Frames devono connettersi a un &3Logistics Module&r per funzionare."
		""
		"{image:pneumaticcraft:textures/patchouli/logistics_module.png width:100 height:100 align:left fit:true}"
	]
	quest.0F49E9167B5E97C9.quest_desc: ["Qualsiasi danno che subisci quando cadi (ignorando l'armatura) verrà inflitto anche ai mob vicini."]
	quest.0F49E9167B5E97C9.quest_subtitle: "Max: 1"
	quest.0FF050EC1EA6EAED.quest_desc: ["Il &3Liquid Hopper&r è un Hopper, ma per liquidi. Non sostituisce i tubi."]
	quest.0FF050EC1EA6EAED.quest_subtitle: "Chi ha bisogno dei tubi?"
	quest.122EDEC12C9A05D2.quest_desc: ["Ho dimenticato di dire che tutto può esplodere?...\\n\\nFortunatamente c'è una soluzione semplice! Il &3Security Upgrade&r quando viene posizionato in una macchina si assicura che non esplodano, inseriscili in qualsiasi macchina in cui possano entrare."]
	quest.122EDEC12C9A05D2.quest_subtitle: "Se solo ci fosse una soluzione facile..."
	quest.122EDEC12C9A05D2.title: "Prevenire le esplosioni?"
	quest.132DF9ECEFFB3B71.quest_desc: ["Il &3Module Expansion Card&r rende il modulo di ricarica ancora migliore."]
	quest.13F68CA518CD287C.quest_desc: ["&3Diesel&r può essere utilizzato per produrre più cherosene o per produrre lubrificante."]
	quest.13F68CA518CD287C.quest_subtitle: "Poor Sel"
	quest.13F68CA518CD287C.title: "Diesel"
	quest.1427B3AB09510D20.quest_desc: ["Crea insieme il tuo PCB non assemblato con 2 condensatori e 2 transistor per ottenere un &3Finished PCB&r."]
	quest.1427B3AB09510D20.quest_subtitle: "Ce l'hai fatta!"
	quest.142C67218BD16867.quest_desc: ["Carica la tua Minigun con questo &3Minigun Ammo&r per usarlo."]
	quest.15007DCAF701B361.quest_desc: ["Carica altri oggetti pressurizzabili nel tuo inventario dal deposito della corazza."]
	quest.15007DCAF701B361.quest_subtitle: "Max: 6"
	quest.15D355EB164EBE68.quest_subtitle: "Necessario per Finished PCBs"
	quest.15D355EB164EBE68.title: "Capacitors"
	quest.187816477B732517.quest_desc: ["Il &3Transfer Gadget&r agisce come una tramoggia che può essere posizionata tra i blocchi."]
	quest.187816477B732517.quest_subtitle: "Smaller Hopper"
	quest.21624A6500545C42.quest_desc: [
		"&3Crop Supports&r può essere posizionato sopra le tue colture per farle crescere più velocemente."
		""
		"{image:atm:textures/questpics/pneumaticcraft/crop_support.png width:200 height:100 align:center}"
	]
	quest.21624A6500545C42.quest_subtitle: "Faster Crops"
	quest.22572456571C3F8D.quest_desc: ["Il &3Charging Module&r depressurizza qualsiasi oggetto pressurizzabile nei contenitori a cui punta."]
	quest.230463E830D6FFEB.quest_desc: ["Ora che abbiamo la plastica, il passo successivo è ottenere dei PCB finiti, prima creare degli &3Empty PCBs&r nella camera a pressione."]
	quest.230463E830D6FFEB.quest_subtitle: "Il percorso verso i PCB"
	quest.2338E5269CA23C91.quest_desc: ["La &3Netherite Drill Bit&r è la migliore punta da trapano, è persino migliore della punta da trapano diamantata."]
	quest.2338E5269CA23C91.quest_subtitle: "Questa è la parte migliore"
	quest.23737103592776C2.quest_desc: ["La &3Kerosene Lamp&r è un'ottima sorgente luminosa che utilizza carburante (il cherosene è il migliore) per produrre luce."]
	quest.23737103592776C2.quest_subtitle: "Le Mega Torce non sono niente!"
	quest.24042326B4632DD4.quest_desc: ["Per iniziare con la creazione logistica di un &3Logistics Core&r, consiglio di leggere il manuale PNC:R per un tutorial completo su come utilizzare questi oggetti."]
	quest.24042326B4632DD4.quest_subtitle: "Trasporto Items/Fluids"
	quest.24042326B4632DD4.title: "Logistics"
	quest.26BEA64C80ECE1A6.quest_desc: ["Ogni &3Logistic Frame&r può essere utilizzato per diverse tipologie di automazione."]
	quest.2745297337E13E9E.quest_desc: ["Il &3Advanced Air Compressor&r funziona allo stesso modo del compressore d'aria, solo molto meglio!"]
	quest.2745297337E13E9E.quest_subtitle: "Non c'è più bisogno dei vecchi e noiosi compressori d'aria!"
	quest.2801B7B6BF61E978.quest_desc: ["&3Kerosene&r può essere utilizzato per produrre benzina o come combustibile in una lampada a cherosene."]
	quest.2801B7B6BF61E978.quest_subtitle: "Hai visto questo, Kero?"
	quest.2801B7B6BF61E978.title: "Kerosene"
	quest.2AED15E3AC0346FE.quest_desc: [
		"Di seguito sono riportati alcuni &3Upgrades&r che puoi utilizzare all'inizio di questa mod. Sposta il mouse mentre passi sopra un &3Upgrade&r per vedere in cosa può essere utilizzato oppure sposta il mouse mentre passi sopra qualcosa per vedere quali aggiornamenti può utilizzare."
		""
		"Nota: il sottotitolo ti dirà la quantità massima di &3Upgrade&r che può essere inserita in qualcosa."
	]
	quest.2AED15E3AC0346FE.quest_subtitle: "Roba molto utile"
	quest.2AED15E3AC0346FE.title: "Simple Upgrades"
	quest.2C5D78630C7AD57F.quest_desc: ["Aumenta la portata, fa cose diverse se utilizzato in cose diverse."]
	quest.2C5D78630C7AD57F.quest_subtitle: "Avvicinati!"
	quest.2CC56A4F06E53307.quest_desc: [
		"Posiziona i tuoi PCB vuoti in un &3UV Light Box&r per caricarli. Ha bisogno di pressione e di accesso alla luce solare."
		"{image:atm:textures/questpics/pneumaticcraft/uv_charging.png width:300 height:150 align:center}"
	]
	quest.2CC56A4F06E53307.quest_subtitle: "Spero che tu abbia degli occhiali da sole!"
	quest.2CC56A4F06E53307.title: "Ricarica con UV"
	quest.2DE7CC686B56881F.quest_desc: ["Ti protegge dalle radiazioni Mekanism."]
	quest.2DE7CC686B56881F.quest_subtitle: "Max: 1"
	quest.2E8F851A4E98F741.quest_desc: [
		"Il &3Pneumatic Armor&r di per sé è piuttosto eccezionale, tuttavia se vuoi rendere straordinaria questa armatura, dovrai installare degli aggiornamenti. Premi \"U\" per impostazione predefinita per aprire la GUI di aggiornamento, alcuni aggiornamenti utilizzano la pressione, altri no."
		""
		"Proprio come per aggiornare altri strumenti in PneumaticCraft, per aggiornare &3Pneumatic Armor&r avrai bisogno di una stazione di ricarica con pressione."
		""
		"Nota: il sottotitolo ti dirà l'importo massimo di quell'aggiornamento che può essere inserito in qualcosa."
	]
	quest.2E8F851A4E98F741.quest_subtitle: "Compressed Iron Man"
	quest.2E8F851A4E98F741.title: "Pneumatic Armor"
	quest.30AD7B15682E4D0E.quest_desc: ["Un segno intelligente che può memorizzare e visualizzare quantità arbitrarie di testo, ridimensionato in modo che il testo si adatti sempre.\\n\\nFai clic con il pulsante destro del mouse con qualsiasi colorante per ricolorare la tessera, puoi colorare il bordo e lo sfondo in modo indipendente."]
	quest.30AD7B15682E4D0E.quest_subtitle: "Segni? Non ne ho mai sentito parlare!"
	quest.312331F6DB0CE5F4.quest_desc: ["Va più veloce del livello I."]
	quest.312331F6DB0CE5F4.quest_subtitle: "Max: 1"
	quest.31BCE63F5E016323.quest_desc: ["Il &3Solar Compressor&r genera pressione utilizzando la luce solare, più diventa caldo, maggiore sarà la pressione che produrrà.\\n\\nTuttavia, fai attenzione, se fa troppo caldo, funzionerà male e dovrai ripararlo."]
	quest.31BCE63F5E016323.quest_subtitle: "Nel palmo della mia mano..."
	quest.31BCE63F5E016323.title: "Pressione dal sole"
	quest.325483DEB0C602F8.quest_desc: ["Questa missione è stata creata da &6AllTheMods Staff&r o da un collaboratore della &2Community&r per l'uso in AllTheMods Modpacks. \\n\\nPoiché tutti i pacchetti &6AllTheMods&r sono concessi in licenza con &eAll Rights Reserved&r, non è consentito utilizzare questa missione in alcun pacchetto pubblico non rilasciato da &6AllTheMods Team&r senza autorizzazione esplicita. \\n\\nQuesta missione è intenzionalmente nascosta, se la vedi significa che sei in modalità di modifica."]
	quest.32C3E14578D48E6C.quest_desc: ["Proprio come i normali &3Pressure Tubes&r, solo questi possono sostenere 10 bar di pressione."]
	quest.32C3E14578D48E6C.quest_subtitle: "Upgraded Pressure Tubes"
	quest.3334D15766A47A46.quest_desc: ["Utilizzando un programma di assemblaggio laser è possibile velocizzare la produzione di &3Unassembled PCBs&r. Basta inserire un PCB vuoto nella cassetta di input, pompare un po' di pressione e attendere."]
	quest.3334D15766A47A46.title: "Automating PCBs"
	quest.36D72D759C4E8823.quest_desc: ["Forse anche un po' troppo veloce."]
	quest.36D72D759C4E8823.quest_subtitle: "Max: 1"
	quest.371A34B297C8A8EF.quest_desc: ["PneumaticCraft è tutta una questione di pressione! Queste missioni non copriranno tutto ciò che la mod ha, ma ne copriranno comunque molto! Ricordati di controllare JEI, leggere i tooltip e leggere PCB:R, sono tutti molto utili.\\n\\nPer iniziare, dovrai creare alcuni &3Compressed Iron Ingots&r! Il modo più semplice per farlo è fare un buco nel terreno, gettarvi dentro alcuni lingotti (o blocchi) di ferro e poi far saltare in aria con un po' di TNT!\\n\\nAlcuni potrebbero perdersi nell'esplosione, ma è un rischio che dovremo correre!"]
	quest.371A34B297C8A8EF.quest_subtitle: "The Power of Air"
	quest.371A34B297C8A8EF.title: "PneumaticCraft: ripressurizzato"
	quest.39F142224D5210A9.quest_desc: ["&3Biodeisel&r può essere utilizzato per realizzare &3Lubricant&r e &3Molten Plastic&r."]
	quest.39F142224D5210A9.quest_subtitle: "Bio/Diesel"
	quest.39F142224D5210A9.title: "Biodeisel"
	quest.3A9AC6AB4407DC32.quest_desc: ["Sebbene non tutte le ricette richiedano gli stessi componenti, puoi configurare il tuo &3Assembly Lines&r con tutto installato. Una semplice configurazione &3Assembly Line&r che può essere utilizzata per tutto è mostrata nell'immagine seguente. Leggi le missioni per ogni componente per alcune informazioni importanti su di essi.\\n\\nGli aggiornamenti di velocità rendono tutto molto più veloce!"]
	quest.3A9AC6AB4407DC32.quest_subtitle: "È richiesto un po' di assemblaggio"
	quest.3A9AC6AB4407DC32.title: "Using Assembly Lines"
	quest.3CFE522A4B7CC2EC.quest_desc: [
		"Il &3Reinforced Chest&r è un baule a prova di esplosione con 36 slot. Non è in grado di raddoppiare il petto. Funziona anche come una scatola Shulker."
		"{image:atm:textures/questpics/pneumaticcraft/reinforced_chest_ui.png width:200 height:100 align:center}"
	]
	quest.3CFE522A4B7CC2EC.quest_subtitle: "Meglio del tuo baule quotidiano"
	quest.3D819550074CA376.quest_desc: ["L'oggetto dovrà essere posizionato qui prima di essere ritirato."]
	quest.3D819550074CA376.quest_subtitle: "Always Required"
	quest.3E16CF590C911129.quest_desc: ["Il &3Air Compressor&r è un modo semplice per esercitare pressione: inserisci semplicemente alcuni oggetti bruciabili e osserva la magia accadere! (Consiglio di realizzarne almeno 3 per iniziare)."]
	quest.3E16CF590C911129.quest_subtitle: "Sentire la pressione"
	quest.3E16CF590C911129.title: "Generating Pressure"
	quest.3F9CCCFEF4E84166.quest_desc: ["Per aumentare la produzione di calore, posiziona un &3Heat Sink&r sul lato freddo del tuo tubo Vortex."]
	quest.3F9CCCFEF4E84166.quest_subtitle: "More Heat"
	quest.3F9CCCFEF4E84166.title: "Better Heat Production"
	quest.40924F0D64253A38.quest_desc: ["Rende le cose in grado di dispensare oggetti."]
	quest.40924F0D64253A38.quest_subtitle: "Andato!"
	quest.40F634AC38F42B88.quest_desc: ["Per spostare la pressione dovrai ottenere &3Pressure Tubes&r. Quale pressione ti starai chiedendo? Continua la serie di missioni per vedere a cosa servono."]
	quest.40F634AC38F42B88.quest_subtitle: "Quale pressione?"
	quest.40F634AC38F42B88.title: "Moving Pressure"
	quest.423B8DA485C1308C.quest_desc: ["&3Gasoline&r può essere utilizzato per produrre GPL."]
	quest.423B8DA485C1308C.quest_subtitle: "Gas, gas, gas"
	quest.423B8DA485C1308C.title: "Gasoline"
	quest.42951D14ADCD9332.quest_desc: ["Potrei mangiarlo con un po' di purè di piselli con un contorno di fagioli tostati, per favore, Governatore?"]
	quest.42951D14ADCD9332.quest_subtitle: "Voglia di Fish & Chipsé"
	quest.42951D14ADCD9332.title: "Pesce\\&Patatine Fritte!"
	quest.43CDC28DC56BB3E2.quest_subtitle: "128,000mb"
	quest.43EF5513A1C52A37.quest_desc: ["Il &3Thermopneumatic Processing Plant&r verrà utilizzato per produrre plastica fusa, pompando semplicemente un po' di GPL, carbone e un po' di calore."]
	quest.43EF5513A1C52A37.quest_subtitle: "Più lungo è il nome, meglio è"
	quest.43EF5513A1C52A37.title: "Thermopneumatic Processing"
	quest.440B1E1D4951F808.quest_desc: [
		"Il &3Smart Chest&r è un baule a prova di esplosione con 72 slot, include una tramoggia omnidirezionale integrata e completamente configurabile e dispone di slot di aggiornamento. Non è in grado di raddoppiare il petto. Funziona anche come una scatola Shulker."
		"{image:atm:textures/questpics/pneumaticcraft/smart_chest_ui.png width:200 height:100 align:center}"
	]
	quest.440B1E1D4951F808.quest_subtitle: "The Nerds of Chests"
	quest.456B9DD108CF340F.quest_desc: ["Rende le cose più veloci."]
	quest.456B9DD108CF340F.quest_subtitle: "Veloce!"
	quest.461C8F1E88AA58D9.quest_desc: [
		"Questi possono essere utilizzati in ricette che utilizzano la versione con secchiello dei liquidi PneumaticCraft.\\n\\nQuando un &3Fluid Tank&r viene messo sopra un altro &3Fluid Tank&r e stretto insieme, diventano un grande serbatoio.\\n"
		"{image:pneumaticcraft:textures/patchouli/small_tanks.png width:250 height:250 align:center fit:true}"
	]
	quest.461C8F1E88AA58D9.quest_subtitle: "32,000mb"
	quest.46BE62C20C720D10.quest_desc: ["Fa sì che gli Endermen non si arrabbino con te come Carved Pumpkins."]
	quest.46BE62C20C720D10.quest_subtitle: "Max: 1"
	quest.482E558BCFEE6B7E.quest_desc: ["Gli &3Construction Bricks&r sono dei fantastici mattoncini, fai attenzione che facciano male. Realizzali di nuovo per renderli lisci."]
	quest.482E558BCFEE6B7E.quest_subtitle: "Non c'è dolore peggiore che calpestarli"
	quest.495DCA49B4E80852.quest_desc: ["La &3Minigun&r è un'arma che necessita di pressione e munizioni per funzionare. Leggi il suggerimento per maggiori informazioni."]
	quest.495DCA49B4E80852.quest_subtitle: "Pew Pew!"
	quest.4A076530297F4A97.quest_desc: [
		"Con questi 3 componenti puoi creare degli &3Elevators&r straordinari.\\n"
		"{image:pneumaticcraft:textures/patchouli/elevator.png width:1 height:1 align:left fit:true}"
	]
	quest.4A076530297F4A97.title: "Elevators"
	quest.4B4F5341D6DBDD19.quest_desc: ["Mantieni il respiro sott'acqua, una volta che le bolle scendono a 5 verranno riempite! Ti permette anche di vedere molto più facilmente sott'acqua!"]
	quest.4B4F5341D6DBDD19.quest_subtitle: "Max: 1"
	quest.4C0D00B5305117A1.quest_desc: [
		"Il &3Sentry Turret&r può essere posizionato da qualche parte e impostato per attaccare mob o giocatori quando sono nel raggio d'azione. Ha solo bisogno di alcune munizioni per minigun."
		""
		"{image:pneumaticcraft:textures/patchouli/sentry_turret.png width:100 height:100 align:left fit:true}"
	]
	quest.4C0D00B5305117A1.quest_subtitle: "Pew Pew (senza di te)"
	quest.4CA17B0A80020B2F.quest_desc: ["&3Manometer&r viene utilizzato per mostrare informazioni aggiuntive su una macchina."]
	quest.4CA17B0A80020B2F.quest_subtitle: "Ho bisogno di più informazioni!"
	quest.4E1E31EDD544EE10.quest_subtitle: "64,000mb"
	quest.4F5348D0C83C3B0D.quest_desc: ["&3Solar Cells&r vengono utilizzati per realizzare compressori solari."]
	quest.4F5348D0C83C3B0D.quest_subtitle: "The Sun's Cells"
	quest.4F5348D0C83C3B0D.title: "Solar Cells"
	quest.4FCC20D9F8F87B2F.quest_desc: ["Il &3Pneumatic Wrench&r viene utilizzato per spostare o rompere macchine e tubi."]
	quest.4FCC20D9F8F87B2F.quest_subtitle: "Coppia sugli strumenti!"
	quest.5103C817381181DE.quest_desc: ["Ti consente di utilizzare un'Elytra mentre indossi ancora la tua corazza pneumatica."]
	quest.5103C817381181DE.quest_subtitle: "Max: 1"
	quest.520EFA7F446AFBF2.quest_desc: ["&3Lubricant&r può essere utilizzato per realizzare punte da trapano."]
	quest.520EFA7F446AFBF2.quest_subtitle: "Produrre lubrificante!"
	quest.520EFA7F446AFBF2.title: "Lubricant"
	quest.521656D425E2FDBA.quest_desc: ["Va ancora più veloce del livello II."]
	quest.521656D425E2FDBA.quest_subtitle: "Max: 1"
	quest.52D3697F1F5625C7.quest_desc: ["&3Etching Acid&r è realizzato nella camera a pressione con plastica fusa... e altre cose. Utilizzato nel serbatoio di incisione."]
	quest.52D3697F1F5625C7.quest_subtitle: "Non chiedere..."
	quest.5303509A1C2B1CCD.quest_desc: ["Il &3Pneumatic Jackhammer&r sfrutta la pressione per estrarre, può essere aggiornato per essere sorprendente!"]
	quest.5303509A1C2B1CCD.quest_subtitle: "Scusa Jack!"
	quest.53518D4ED99A242F.quest_desc: ["Il &3Camouflage Applicator&r può essere utilizzato per nascondere i macchinari PneumaticCraft all'interno di altri blocchi."]
	quest.53518D4ED99A242F.quest_subtitle: "Vuoi rendere interessante la tua configurazione?"
	quest.54169B69725C49DF.quest_desc: ["Posiziona la tua plastica liquida a terra o conservane un po' in una cassa con una struttura termica attaccata ed ecco il tuo &3Plastic Sheet&r!"]
	quest.54169B69725C49DF.quest_subtitle: "Finalmente!"
	quest.54169B69725C49DF.title: "&fPlastic"
	quest.5A0860631323B5E3.quest_desc: ["Prodotto con &3Wheat Flour&r. Can be used to make Salmon Tempura and Sourdough Bread."]
	quest.5A0860631323B5E3.quest_subtitle: "Impasta questo"
	quest.5A9D6672385D3D82.quest_desc: ["Usa solo 1 Lapis per un aggiornamento invece di 4."]
	quest.5A9D6672385D3D82.quest_subtitle: "Saving Lapis"
	quest.5AEE86EB39FD4087.quest_desc: ["Il &3Vortex Tube&r separa la pressione in aria calda e aria fredda. L'aria fredda va verso il lato blu e l'aria calda verso il lato rosso."]
	quest.5AEE86EB39FD4087.quest_subtitle: "Ancora non RF..."
	quest.5AEE86EB39FD4087.title: "Heat Production"
	quest.5B9F933ECD6B24FD.quest_desc: ["Ti consente di saltare più in alto rispetto al livello II."]
	quest.5B9F933ECD6B24FD.quest_subtitle: "Max: 1"
	quest.5C7D9BCDF19B86BD.quest_desc: ["Impedisce alle cose di esplodere."]
	quest.5C7D9BCDF19B86BD.quest_subtitle: "Sicuro!"
	quest.5D64250B940BC8FD.quest_desc: ["Il ferro compresso può essere utilizzato per creare &3Compressed Iron Armor&r, è uguale all'armatura di ferro ma con robustezza dell'armatura e resistenza al contraccolpo migliori.\\n\\nL'armatura può essere creata o può essere trovata comunemente nei forzieri."]
	quest.5D64250B940BC8FD.quest_subtitle: "Grande resistenza al contraccolpo"
	quest.5D64250B940BC8FD.title: "Compressed Iron Armor"
	quest.5D71ED16FD4E725A.quest_desc: ["Rende Piglins passivo (come indossare un'armatura d'oro), devi solo mettere l'aggiornamento su un pezzo."]
	quest.5D71ED16FD4E725A.quest_subtitle: "Max: 1"
	quest.5D7B34761E8FD212.quest_desc: [
		"Il &3Electrostatic Compressor&r genera molta pressione dai Lightning Strikes.\\n\\nPer maggiori informazioni controlla la scheda \"Informazioni\" in JEI.\\n"
		"{image:pneumaticcraft:textures/patchouli/electrostatic_compressor.png width:100 height:100 align:left fit:true}"
	]
	quest.5D7B34761E8FD212.title: "Pressione da fulmine"
	quest.5E71F8A046C60346.quest_desc: ["Chi ti ha detto che PneumaticCraft non riguardava la generazione di energia?\\n\\n&3Pneumatic Dynamo&r ti consente di trasformare la tua pressione in FE. Leggi il tooltip o leggilo nel PNC:R per sapere come funziona."]
	quest.5E71F8A046C60346.quest_subtitle: "Pressure = Power"
	quest.5E71F8A046C60346.title: "Generating Power"
	quest.602C3E88D96F8843.quest_desc: ["Metti un PCB vuoto carico nel serbatoio di incisione con un po' di acido di incisione e un po' di calore e otterrai un &3Unassembled PCBs&r."]
	quest.602C3E88D96F8843.quest_subtitle: "Ci siamo quasi!"
	quest.61AD2207E770CD7F.quest_desc: ["Ti consente di raccogliere oggetti ed esperienze da più lontano."]
	quest.61AD2207E770CD7F.quest_subtitle: "Max: 6"
	quest.61B479079DC1C69C.quest_desc: ["Ti consente di saltare più in alto rispetto al livello I."]
	quest.61B479079DC1C69C.quest_subtitle: "Max: 1"
	quest.61BA2932EC86DA2E.quest_desc: ["Ti permette di saltare MOLTO in alto."]
	quest.61BA2932EC86DA2E.quest_subtitle: "Max: 1"
	quest.63F6F4EBCEB914B0.quest_desc: ["La &3Pressure Chamber&r è un'importante struttura multiblocco composta da &3Pressure Chamber Walls&r (Le facce possono essere sostituite con &3Pressure Chamber Glass&r). La camera a pressione può essere piccola quanto un multiblocco 3x3x3 o grande quanto un multiblocco 5x5x5. I blocchi richiesti per il 5x5x5 sono ciò che serve per completare questa missione.\\n\\nPer utilizzare la camera a pressione dovrai convogliare la pressione in un &3Pressure Chamber Valve&r utilizzando il &3Pressure Tubes&r che hai creato in precedenza, ricordati di inserire un aggiornamento di sicurezza nella valvola a pressione. &lDifferent recipes require different amounts of pressure&r.\\n\\nDovrai essere in grado di inserire ed estrarre oggetti da e verso la camera a pressione, è qui che entra in gioco &3Pressure Chamber Interfaces&r. Il blu all'esterno significa che serve per importare oggetti, mentre se l'oro è all'esterno serve per esportare oggetti, posizionane uno su qualsiasi faccia."]
	quest.63F6F4EBCEB914B0.quest_subtitle: "Pressurizzazione!"
	quest.63F6F4EBCEB914B0.title: "The Pressure Chamber"
	quest.649167FC31EB916E.quest_desc: ["&3Vegetable Oil&r può essere creato inserendo raccolti o semi in un &3Thermopneumatic Processing Plant&r."]
	quest.649167FC31EB916E.quest_subtitle: "Better Oil"
	quest.649167FC31EB916E.title: "Vegetable Oil"
	quest.64D34A6C3487C5DF.quest_desc: ["Il &3Aerial Interface&r può essere utilizzato per riempire di pressione i tuoi oggetti pressurizzabili. Ora puoi usare la tua Armatura pneumatica senza bisogno di ricaricarla!\\n\\nAvrai bisogno di una di queste per creare il &6ATM Star&r."]
	quest.64D34A6C3487C5DF.quest_subtitle: "Pressione senza fili!"
	quest.64E2E05B228EA53E.quest_desc: ["Gli &3Advanced Pressure Tubes&r sono i migliori tubi a pressione disponibili, essendo in grado di sostenere 20 bar di pressione!\\n\\nSebbene siano davvero fantastici da soli, possono essere utilizzati anche in alcune ricette ancora più interessanti."]
	quest.64E2E05B228EA53E.quest_subtitle: "Un livello completamente nuovo!"
	quest.657DB994B029F61C.quest_desc: [
		"Quando il &3Heat Frame&r viene posizionato su un contenitore contenente determinati fluidi e reso sufficientemente freddo, trasformerà tali fluidi in oggetti."
		""
		"Trasforma la plastica fusa in plastica."
		"Trasforma l'acqua in ghiaccio."
		"Trasforma la lava in ossidiana."
	]
	quest.65E2AF881709C896.quest_desc: ["Uno dei materiali più importanti di cui avrai bisogno è &3Reinforced Stone&r, inizia creandone 32 usando ferro compresso e qualche pietra normale."]
	quest.65E2AF881709C896.quest_subtitle: "Ne avrai bisogno molto"
	quest.65E2AF881709C896.title: "Reinforced Stone"
	quest.6674270897997BF7.quest_desc: ["Ti permette di saltare più in alto del solito e ti rende elastico, permettendoti di viaggiare più velocemente.\\n\\nPuoi avere solo un livello di questi potenziamenti alla volta nei Gambali."]
	quest.6674270897997BF7.quest_subtitle: "Max: 1"
	quest.681A3F31FB242555.quest_desc: ["&3Ethanol&r può essere utilizzato per produrre biodiesel."]
	quest.681A3F31FB242555.title: "Ethanol"
	quest.68F92455A9483AD6.quest_desc: ["Vedrai questa missione solo se hai usato gli Stivali Jet.\\n\\nNon c'è modo di usare gli Stivali Jet senza subire danni, non provarci nemmeno..."]
	quest.68F92455A9483AD6.quest_subtitle: "Pensavi che usare un'Elytra fosse difficile?"
	quest.68F92455A9483AD6.title: "Jet Boots"
	quest.6B1C06C753C10E44.quest_desc: ["&3Logistics Configurator&r può essere utilizzato per configurare frame logistici e gadget di trasferimento."]
	quest.6CA01DCE1F4A0EC3.quest_desc: ["La fase successiva della mod richiede la raccolta di &3Crude Oil&r. Questo olio può essere trovato naturalmente sulla superficie dell'overworld."]
	quest.6CA01DCE1F4A0EC3.quest_subtitle: "The Path to Plastic"
	quest.6CA01DCE1F4A0EC3.title: "Crude Oil"
	quest.6D124ACF4AE80490.quest_desc: ["Con i Micromissili puoi sparare esplosioni da molto lontano! Ora nessuno può scappare!\\n\\nSono necessarie le tesi per creare il &6ATM Star&r."]
	quest.6D124ACF4AE80490.quest_subtitle: "Sparando esplosioni da lontano!"
	quest.6EB53CDCB80D4B66.quest_desc: [
		"&3Pneumatic Door&r funge da porta automatica che può essere fatta aprire solo per te!"
		""
		"{image:pneumaticcraft:textures/patchouli/pneumatic_door.png width:200 height:200 align:right fit:true}"
	]
	quest.6FD65139CD50A8C0.quest_desc: ["È possibile?\\n\\nSe desideri automatizzare questo processo puoi utilizzare &eProductive Bees&r o &aMystical Agriculture&r. Oppure immagino che potresti automatizzarlo, con... esplosioni."]
	quest.6FD65139CD50A8C0.quest_subtitle: "Stanco di far esplodere le cose?"
	quest.7040CA41C0A3C2F2.quest_desc: [
		"&3PCB Blueprints&r IN VENDITA ORA per 8 Smeraldi. (Solo per un periodo limitato)."
		"{@pagebreak}"
		"(nuovo testo segnaposto della pagina)"
	]
	quest.7040CA41C0A3C2F2.quest_subtitle: "Grazie Amadron!"
	quest.7040CA41C0A3C2F2.title: "&9PCB Blueprint"
	quest.715B86DC82EA636B.quest_desc: [
		"Il &3Liquid Compressor&r crea pressione utilizzando determinati liquidi. Puoi inserire il carburante facendo clic con il pulsante destro del mouse sul secchio sulla macchina, pompando il fluido o inserendo un secchio nello slot superiore della GUI."
		""
		"{image:pneumaticcraft:textures/gui/gui_liquid_compressor.png width:200 height:200 align:center fit:true}"
	]
	quest.715B86DC82EA636B.title: "Pressione da liquidi"
	quest.7177E49BF9ECA5CF.quest_desc: [
		"Il &3Thermal Compressor&r crea pressione utilizzando il calore! Metti qualcosa di caldo da un lato e qualcosa di freddo dall'altro per creare pressione."
		""
		"{image:pneumaticcraft:textures/patchouli/thermal_compressor.png width:100 height:100 align:left fit:true}"
	]
	quest.7177E49BF9ECA5CF.title: "Pressione dal calore"
	quest.718DABA6C9E5982A.quest_desc: ["Concede al giocatore Visione notturna quando indossato."]
	quest.718DABA6C9E5982A.quest_subtitle: "Max: 1"
	quest.72C09FD89C28B1EC.quest_desc: [
		"Il &3Oil Refinery&r che realizzeremo è un multiblocco 1x1x5 composto da 1 &3Refinery Controller&r (in basso) e quattro &3Refinery Outputs&r (in alto). Dovrai inserire olio e calore affinché funzioni. Questo produrrà diesel, cherosene, benzina e GPL. Mettere &3Thermal Laggings&r sui lati aiuta a mantenerlo caldo."
		""
		"{image:atm:textures/questpics/pneumaticcraft/oil_refinery.png width:300 height:150 align:center}"
	]
	quest.72C09FD89C28B1EC.quest_subtitle: "Ora stiamo arrivando da qualche parte"
	quest.72C09FD89C28B1EC.title: "Oil Refinery"
	quest.7386A8433698946C.quest_desc: [
		"Seleziona un oggetto e questo aggiornamento lo cercherà nelle vicinanze nei forzieri o sul pavimento. Per trovarlo nei forzieri sarà necessario il potenziamento Tracciatore di blocchi e per trovarlo sul pavimento sarà necessario il potenziamento Tracciatore di entità.\\n"
		"{image:atm:textures/questpics/pneumaticcraft/item_search_upgrade.png width:200 height:200 align:center}"
	]
	quest.7386A8433698946C.quest_subtitle: "Max: 1"
	quest.7395B41685F4BC1A.quest_desc: ["Il &3Flux Compressor&r può creare un'enorme pressione utilizzando la potenza. Basta semplicemente pompare un po' di FE e inizierà a generarne un po'. Se hai abbastanza FE da spendere, questo è probabilmente il modo più semplice per generare pressione."]
	quest.7395B41685F4BC1A.quest_subtitle: "Power = Pressure"
	quest.7395B41685F4BC1A.title: "Pressioni del potere"
	quest.74015945716FD10A.quest_desc: ["Thie &3Omnidirectional Hopper&r può inserire oggetti da qualsiasi lato, inoltre può essere aggiornato per essere molto più veloce di un normale Hopper! Bello per quando i tubi non sono necessari."]
	quest.74015945716FD10A.quest_subtitle: "Una tramoggia configurabile"
	quest.74AE214747A3DB1A.quest_desc: ["Aumenta la pressione che le cose possono sopportare."]
	quest.74AE214747A3DB1A.quest_subtitle: "Alza il volume!"
	quest.75D3F3C1D4A3EAA2.quest_desc: ["Per spostare il calore prodotto dal tubo Vortex, crea un po' di &3Heat Pipes&r."]
	quest.75D3F3C1D4A3EAA2.quest_subtitle: "Abbiamo il calore di muoverci:)"
	quest.75D3F3C1D4A3EAA2.title: "Moving Heat"
	quest.762B8309E1A31B99.quest_desc: ["Ogni potenziamento aggiunge +0,5 alla difesa dell'armatura e +1 alla resistenza dell'armatura."]
	quest.762B8309E1A31B99.quest_subtitle: "Max: 4"
	quest.7770F0D62457096D.quest_desc: ["Anche se queste missioni non riguardano i droni, sono fantastiche! Prova a usarli se vuoi."]
	quest.7770F0D62457096D.title: "Programming Drones"
	quest.795143471F31A64A.quest_subtitle: "Richiesto per Laser recipes"
	quest.7953C87C488A2AF7.quest_desc: ["Ti permette di volare come Iron Man.\\n\\nPuoi avere solo un livello di questi potenziamenti alla volta negli Stivali. Ogni livello utilizzerà più pressione del precedente.\\n\\nUsa questi potenziamenti, non limitarti a crearli."]
	quest.7953C87C488A2AF7.quest_subtitle: "Max: 1"
	quest.7B2008977702D0C8.quest_desc: ["Quando si esercita pressione in un compressore d'aria, se non si ha un posto dove indirizzare la pressione. semplicemente scomparirà. Assicurati di avere un posto dove andare la pressione prima di farne qualcuno."]
	quest.7B2008977702D0C8.quest_subtitle: "Cosa è successo a RF o FE?"
	quest.7BFC24607189B6D0.quest_desc: ["Ti fa nuotare più velocemente."]
	quest.7BFC24607189B6D0.quest_subtitle: "Max: 1"
	quest.7BFE7DAF18981843.quest_subtitle: "Richiesto per Drill recipes"
	quest.7D6B4AEF806AF62E.quest_desc: ["100% troppo veloce! Cerca di non morire!"]
	quest.7D6B4AEF806AF62E.quest_subtitle: "Max: 1"
	quest.7D81F2381516204D.quest_subtitle: "Necessario per Finished PCBs"
	quest.7D81F2381516204D.title: "Transistors"
	quest.7FB12EC3A5888123.quest_desc: ["Il &3Tube Junction&r ti offre un maggiore controllo sul trasporto della pressione consentendoti di spostare i tubi di pressione in più direzioni."]
	quest.7FB12EC3A5888123.quest_subtitle: "No, vai da questa parte!"
	task.0B54EDC9E21F2E77.title: "Logistics Frames"
	task.13266875BDB5077D.title: "TuttiIDirittiRiservati"
	task.1EEC7B67E037F766.title: "Understanding Pressure"
	task.25FF884779D98BAD.title: "Construction Bricks™"
	task.2C268116DA162155.title: "TuttiIDirittiRiservati"
