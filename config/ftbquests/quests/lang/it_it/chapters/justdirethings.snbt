	quest.5B02719C13B1FFE2.quest_desc: [
		"Abilities:"
		"- Air Burst: distanza di lancio ulteriormente migliorata."
		"- Spostamento del vuoto: distanza di teletrasporto migliorata."
		"- Eclipse Gate: crea un buco portatile in un'area 3x3, la direzione dipende dalla faccia del blocco preso di mira. La distanza del foro creato è configurabile. Nota Eclipse Gate non funziona su entità riquadro."
	]
	quest.5B910F1389C0B915.quest_desc: [
		"Abilities:"
		"- Air Burst: migliorata la distanza di lancio e il consumo di FE."
		"- Spostamento del vuoto: teletrasporta il giocatore nella direzione in cui guarda, consumando FE nel processo."
	]
	quest.5BBE8B30ED7518B8.quest_desc: [
		"Valid Upgrades:"
		"- Ore Miner"
		"- Scanner per minerali &4&lDISABLED&r&f"
	]
	quest.5BD5737703F3F077.quest_desc: ["Ferricore è un nuovo materiale aggiunto da JDT. Il Ferricore si ottiene eseguendo la diffusione della sostanza appiccicosa sui blocchi di ferro utilizzando la sostanza appiccicosa di livello uno o superiore. Ferricore Ore è influenzato dalla fortuna."]
	quest.5BD5737703F3F077.title: "Ferricore"
	quest.5C6709350BEF4050.quest_desc: [
		"Voidshimmer Goo è il terzo livello di sostanza appiccicosa aggiunta da JDT e richiede materiali End per essere realizzato."
		""
		"Crafts Unlocked:"
		"- Celestigem"
		"- Void Flame"
	]
	quest.5D4E51471F3939E0.quest_desc: [
		"Abilites:"
		"- Air Burst: lancia il giocatore nella direzione in cui si trova, consumando durabilità nel processo, le bacchette di livello più alto lanciano il giocatore a una distanza maggiore. Nota che il giocatore non subirà danni da caduta finché tiene in mano la bacchetta."
	]
	quest.5EE7D5DE07A83C7D.quest_desc: ["&lAbility Type:&r Attivo\\n\\n&lAbility Function:&r\\n\\nEvidenzia i minerali vicini con particelle verdi quando attivato.\\n\\n&4&lNOTE THIS ABILITY HAS BEEN DISABLED.&r&f"]
	quest.5F5120451BA5B2FE.quest_desc: ["Le macchine avanzate hanno le stesse funzionalità delle loro varianti semplici con l'aggiunta di un'area di lavoro configurabile, più slot per filtri e richiedono energia."]
	quest.60A4994078500F63.quest_desc: ["Celestigem è un nuovo materiale aggiunto da JDT. Celestigem viene acquisito eseguendo la diffusione della sostanza appiccicosa sui blocchi di diamante utilizzando la sostanza appiccicosa di livello tre o superiore. Celestigem Ore è influenzato dalla fortuna."]
	quest.61213012615619C5.quest_desc: [
		"&lAbility Type:&r Passivo"
		""
		"&lAbility Function:&r"
		""
		"Fuma automaticamente gli oggetti lasciati cadere dalle uccisioni."
	]
	quest.636854555AD75DC3.quest_desc: [
		"&lAbility Type:&r Passivo"
		""
		"&lAbility Function:&r"
		""
		"Teletrasporta automaticamente gli oggetti rilasciati nell'inventario associato allo strumento. Shift Right Facendo clic sullo strumento su un inventario lo si vincola. Nota quando su una zappa JDT gli oggetti rilasciati dall'abilità di raccolta automatica dei terreni agricoli voidshimmer / shadowpulse vengono teletrasportati nell'inventario rilegato, anche facendo clic con il pulsante destro del mouse sui terreni agricoli voidshimmer / shadowpulse li legherai nuovamente se l'inventario rilegato dello strumento è stato modificato."
	]
	quest.6690AEE064DC2A7C.quest_desc: [
		"&lAbility Type:&r Passivo"
		""
		"&lAbility Function:"
		""
		"Aumenta l'area estratta contemporaneamente. Se installato su strumenti di livello superiore, l'area massima estratta viene aumentata. L'area minata può essere configurata nel menu."
	]
	quest.6720F863B907A5F1.quest_desc: [
		"&lAbility Type:&r Passivo"
		""
		"&lAbility Function:&r"
		""
		"Fa sì che le frecce pozione scagliate dall'arco abbiano un effetto persistente, applicando effetti a un'area nel tempo."
	]
	quest.6737CB17D562B134.quest_desc: ["Basta un semplice clicker che fa clic con l'oggetto che gli viene assegnato."]
	quest.67B87570C340C243.title: "Armor Upgrades"
	quest.6889EFC6CC291463.quest_desc: [
		"&lAbility Type:&r Attivo"
		""
		"&lAbility Function:&r"
		""
		"Respinge i mob vicini quando attivato, ha un tempo di recupero."
	]
	quest.6A4D31194C4CE156.quest_desc: [
		"Valid Upgrades:"
		"- Ore Miner"
		"- Lawnmower"
		"- Sky Sweeper"
