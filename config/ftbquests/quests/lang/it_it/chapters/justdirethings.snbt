		""
		"&lAbility Function:&r"
		""
		"Fa sì che le frecce scagliate dall'arco applichino un effetto di pozione basato sul tuo contenitore di pozioni."
	]
	quest.05D8C6EF8FCD6250.quest_desc: [
		"Primogel Goo è il primo livello di sostanza appiccicosa aggiunta da JDT e richiede materiali Overworld di base per essere realizzato."
		""
		"Crafts Unlocked:"
		"- Ferricore"
		"- Primal Coal"
		""
		"Goo Spread Example:"
		""
		"{image:atm:textures/questpics/justdirethings/goo_spread_ferricore.png width:200 height:200 align:center}"
	]
	quest.07655CA904354E9E.quest_desc: [
		"&lAbility Type:&r Attivo"
		""
		"&lAbility Function:"
		""
		"Quando viene attivato, spezza l'erba e i fiori vicini."
	]
	quest.079A415488A32076.quest_desc: ["Blaze Ember è un nuovo materiale aggiunto da JDT. Blaze Ember si ottiene eseguendo la diffusione della sostanza appiccicosa sui blocchi di carbone primordiale utilizzando la sostanza appiccicosa di livello due o superiore. Blaze Ember Ore è influenzato dalla fortuna."]
	quest.09485B63483B7A15.quest_desc: [
		"&lAbility Type:&r Attivo"
		""
		"&lAbility Function:"
		""
		"Fa temporaneamente perdere aggressività ai mob ostili vicini al giocatore, ha un tempo di recupero."
	]
	quest.09D2137B4F42006E.quest_desc: ["Eclipse Ember è un nuovo materiale aggiunto da JDT. Eclipse Ember viene acquisito eseguendo la diffusione della sostanza appiccicosa sui blocchi di carbone di Voidflame utilizzando la sostanza appiccicosa di livello quattro. Il Minerale Eclipse Ember è influenzato dalla fortuna."]
	quest.0A02DBE226C3F44E.quest_desc: [
		"Valid Upgrades:"
