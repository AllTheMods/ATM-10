	quest.2409EAD96CE3BDF7.quest_desc: ["I modelli Blazegold vengono utilizzati per potenziare l'armatura e gli strumenti Ferricore in Blazegold mantenendo gli incantesimi e i potenziamenti installati."]
	quest.242F74010488F261.quest_desc: ["La tanica di carburante è un oggetto che consente un utilizzo più efficiente del carburante. Può immagazzinare 50.000 unità di carburante, ogni oggetto bruciabile ha un valore di carburante diverso a seconda della quantità di oggetti fusi. Un carburante è sufficiente per fondere un oggetto."]
	quest.24BA4B4EED0A9DBD.quest_desc: [
		"Valid Upgrades:"
		"- Mind Fog"
	]
	quest.25213DBA6E6CEDD2.quest_desc: [
		"Shadowpulse Goo è il quarto e ultimo livello di sostanza appiccicosa aggiunta da JDT e richiede materiali della Città Antica e del Guardiano per essere realizzato."
		""
		"Crafts Unlocked:"
		"- Eclipse Alloy"
		"- Eclipse Ember"
		"- Time Crystal"
	]
	quest.25E915AE1FC53254.quest_desc: ["I modelli Celestigem vengono utilizzati per potenziare l'armatura e gli strumenti Blazegold in Celestigem mantenendo gli incantesimi e i potenziamenti installati."]
	quest.27FD46A8C958D259.quest_desc: ["Totem of Death Recall è un gioco monouso che consente al giocatore di teletrasportarsi nel luogo della morte."]
	quest.283D7E65F2AD45F2.quest_desc: [
		"&lAbility Type:&r Attivo"
		""
		"&lAbility Function:&r"
