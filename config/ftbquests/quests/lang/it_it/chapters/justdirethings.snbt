	quest.2875FACD3BFB0A8E.quest_desc: [
		"&lAbility Type:&r Attivo"
		""
		"&lAbility Function:&r"
		""
		"Fornisce una guarigione minore quando attivato, ma può essere attivato solo se il giocatore ha recentemente subito danni o sta subendo danni."
	]
	quest.2A01CE9206DD4F8A.quest_desc: [
		"&lAbility Type:&r Passivo"
		""
		"&lAbility Function:&r"
		""
		"Estrae i blocchi di minerale adiacenti tutti in una volta, ma richiede leggermente più tempo per l'estrazione."
