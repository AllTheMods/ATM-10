	quest.4E9B35DCA018FD42.title: "Tool Upgrades"
	quest.4F9932477EDDCB8E.quest_desc: ["L'Advanced Portal Gun è la versione aggiornata della Portal Gun che richiede sia energia che fluido del portale per funzionare. A differenza della Portal Gun, la Advanced Portal Gun consente al giocatore di teletrasportarsi tra luoghi che sono stati codificati. Usando \"V\" (combinazione di tasti predefinita) il menu utilizzato per codificare e selezionare le destinazioni per il teletrasporto."]
	quest.5054977BD5354561.quest_desc: [
		"Valid Upgrades:"
		"- Tree Feller"
		"- Leaf Breaker"
	]
	quest.515C0527226BA50C.quest_desc: [
		"&lAbility Type:&r Passivo"
		""
		"&lAbility Function:&r"
		""
		"Concede al giocatore il volo creativo."
	]
	quest.517F0135926B15EE.quest_desc: ["Tutte le macchine semplici sono dotate di controllo della pietra rossa e alcune sono dotate di filtro."]
	quest.52EC86E03EB50525.quest_desc: [
		"Intrinsic Ability:"
		"- Lava Repair"
		"- No Trampling"
		"- Auto Harvesting"
		"- Crescita accelerata delle colture II"
	]
	quest.53F9E5CE7EE6F852.quest_desc: ["Il Creature Catcher consente il trasporto di mob. I mob possono essere inseriti nella lista nera tramite un tag entità."]
	quest.567005978482235F.quest_desc: [
