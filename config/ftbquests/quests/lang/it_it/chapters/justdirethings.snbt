	]
	quest.0B485DB737A036E9.quest_desc: ["La copiatrice delle impostazioni della macchina consente ai giocatori di copiare le impostazioni tra le macchine."]
	quest.0B9BBE2A764631BF.quest_desc: ["Il semplice scambiatore può teletrasportare oggetti, blocchi, mob o giocatori sopra di esso su un altro semplice scambiatore a cui è collegato. Per collegare gli scambiatori utilizzare la chiave Ferricore."]
	quest.0C1D55AA9CC902BD.quest_desc: [
