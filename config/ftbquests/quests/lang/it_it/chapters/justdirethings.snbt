	quest.4B3F20E5C7E3BCFB.quest_desc: ["Primal Coal è un nuovo materiale aggiunto da JDT. Il carbone primordiale viene acquisito eseguendo la diffusione della sostanza appiccicosa sui blocchi di carbone utilizzando la sostanza appiccicosa di livello uno o superiore. Il minerale di carbone primordiale è influenzato dalla fortuna."]
	quest.4C54BD57CAB8A54B.quest_desc: [
		"Blazebloom Goo è il secondo livello di sostanza appiccicosa aggiunta da JDT e richiede materiali Nether per essere realizzato."
		""
		"Crafts Unlocked:"
		"- Blazegold"
		"- Blaze Ember"
	]
	quest.4D98D2123BD5BFB3.quest_desc: [
		"&lAbility Type:&r Passivo"
		""
		"&lAbility Function:&r"
		""
		"Estrae i tronchi adiacenti tutti in una volta, nota che aumenterà il tempo necessario per rompersi quando si estraggono più tronchi."
	]
	quest.4E03AE15BEF86178.quest_desc: [
