	quest.5961C1ED32522BEF.quest_desc: [
		"&lAbility Type:&r Attivo"
		""
		"&lAbility Function:&r "
		""
		"Genera un'esca del giocatore che allontana l'aggro dal giocatore, ha un tempo di recupero."
	]
	quest.5A1AB1AD7DEFDD9A.quest_desc: [
		"Valid Upgrades:"
