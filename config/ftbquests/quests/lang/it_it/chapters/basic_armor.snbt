	quest.1245126B4338C019.title: "Vex Armor Trim"
	quest.13517D17E6BF015F.quest_desc: ["Con &bDiamond Armor&r e alcuni &aInferium Items&r possiamo creare &aInferium Armor&r! \\n\\nPossono anche essere migliorati con il Tinkering!"]
	quest.13517D17E6BF015F.quest_subtitle: "21"
	quest.13517D17E6BF015F.title: "&aInferium Armor"
	quest.1366B946928C873B.quest_desc: ["Controlla la pagina delle missioni &6&lBumblezone&r per saperne di più!"]
	quest.1366B946928C873B.quest_subtitle: "10"
	quest.1366B946928C873B.title: "Bee Armor 1"
