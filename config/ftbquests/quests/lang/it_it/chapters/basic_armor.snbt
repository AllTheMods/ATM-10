	quest.10AA2B20D86747F7.quest_desc: ["&bFerricore&r ha le stesse statistiche di Iron ma ha altre abilità che Iron vorrebbe avere! \\n\\nDai un'occhiata alle descrizioni degli articoli per saperne di più su cosa possono fare!"]
	quest.10AA2B20D86747F7.quest_subtitle: "15"
	quest.10AA2B20D86747F7.title: "&bFerricore Amor"
