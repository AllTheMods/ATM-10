	quest.140DF670162C68DA.title: "&aSteeleaf"
	quest.1452D9CF827782B5.quest_desc: ["Arctic Gear è realizzato con pelliccia artica. La pelliccia artica è stata rilasciata da Winter Wolves and Yetis! \\n\\nNo, non puoi tosare nessuno dei due. \\n\\nL'equipaggiamento può essere tinto come &7Leather Armor&r!"]
	quest.1452D9CF827782B5.quest_subtitle: "16"
	quest.1452D9CF827782B5.title: "&fArctic Gear"
	quest.15978093237448FE.quest_desc: ["Perché aggiornare &cNetherite&r a &6Allthemodium&r o anche qualsiasi altra cosa quando possiamo aggiornarlo a &3Warden Armor&r! \\n\\nAvrai bisogno di alcuni Warden Drops per farcela!"]
	quest.15978093237448FE.quest_subtitle: "24"
	quest.15978093237448FE.title: "&3Warden Armor"
	quest.16359196D49A6223.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_froststeel.png width:100 height:150 align:center}"]
	quest.16359196D49A6223.title: "&bFroststeel&r"
	quest.17A68C4E9E9EA2B7.quest_desc: ["&eGolden Armor&r è giusto tra Iron and &7Leather&r. Ma la sua durabilità è molto più vicina a quella di &7Leather&r. \\n\\nNon serve a molto, oltre ad avere Piglins neutrale nei tuoi confronti quando indossi un'armatura &eGold&r."]
	quest.17A68C4E9E9EA2B7.quest_subtitle: "11"
	quest.17A68C4E9E9EA2B7.title: "&eGolden Armor"
	quest.19F58E291A543228.quest_desc: ["Versione &eGold&r delle armature &d&lArs&r!"]
	quest.19F58E291A543228.quest_subtitle: "11"
	quest.19F58E291A543228.title: "&5Vestito da stregone"
	quest.1A8440C0048EEB02.quest_desc: ["&cBlazegold&r ha le stesse statistiche di Iron ma ha altre abilità che Iron vorrebbe avere! \\n\\nDai un'occhiata alle descrizioni degli articoli per saperne di più su cosa possono fare!"]
	quest.1A8440C0048EEB02.quest_subtitle: "15"
	quest.1A8440C0048EEB02.title: "&cBlazegold Armor"
	quest.1C27C74722A19FC1.quest_desc: ["Con un sacco di &l&5Mekanism&r Items super costosi puoi aggiornare &5Unobtainium Armor&r a &aMekaSuit&r! \\n\\nOra può contenere Energy and invece di prendere cuori dai danni, prenderà Energy. \\n\\nPuoi usare Upgrade Units per renderlo ancora migliore!"]
	quest.1C27C74722A19FC1.quest_subtitle: "Tutto il Energy che puoi fornire"
