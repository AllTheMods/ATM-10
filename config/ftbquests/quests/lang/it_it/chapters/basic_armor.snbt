{
	quest.004D61425172324F.quest_desc: ["&8Chainmail Armor&r è un po' peggio di Iron. Il suo utilizzo principale in &l&2Minecraft&r era la sua natura sfuggente, essendo ottenibile solo tramite Trades and Mob Drops. \\n\\nOvviamente è stato modificato, quindi possiamo realizzarlo ora! Il che gli toglie lo scopo..."]
	quest.004D61425172324F.quest_subtitle: "12"
	quest.004D61425172324F.title: "&8Chainmail Armor"
	quest.041ED280691BB05D.quest_desc: ["&9Froststeel&r è un minerale comune nei biomi freddi del &2&lSottogiardino&r. "]
	quest.041ED280691BB05D.quest_subtitle: "18"
	quest.041ED280691BB05D.title: "&9Froststeel Armor"
	quest.04B31A600004F7CB.quest_desc: ["Questa missione è stata creata da &6AllTheMods Staff&r o da un collaboratore della &2Community&r per l'uso in AllTheMods Modpacks. \\n\\nPoiché tutti i pacchetti &6AllTheMods&r sono concessi in licenza con &eAll Rights Reserved&r, non è consentito utilizzare questa missione in alcun pacchetto pubblico non rilasciato da &6AllTheMods Team&r senza autorizzazione esplicita. \\n\\nQuesta missione è intenzionalmente nascosta, se la vedi significa che sei in modalità di modifica."]
	quest.055CCAE237DF3EEF.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_ironwood.png width:100 height:150 align:center}"]
	quest.055CCAE237DF3EEF.title: "&8Ironwood"
	quest.05B5E640F1B68A28.quest_desc: ["{image:atm:textures/questpics/basicarmor/armor_golem.png width:100 height:150 align:center}"]
	quest.05B5E640F1B68A28.title: "&3Golem Steel&r"
	quest.074EC1E636CD6605.quest_desc: ["&cArmatura Netherite&r è la migliore che &l&2Vanilla&r possa ottenere. Ha lo stesso Armor Points di &bDiamond&r ma più Armor Toughness. \\n\\nProbabilmente perché hai bisogno di &bDiamond&r per realizzarlo!"]
	quest.074EC1E636CD6605.quest_subtitle: "20"
	quest.074EC1E636CD6605.title: "&cNetherite Armor"
	quest.0ABB2264CBB82470.quest_desc: ["Iron Armor di &d&lArs&r Armatura."]
