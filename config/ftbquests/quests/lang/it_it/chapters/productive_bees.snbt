	quest.06044B4452A6B720.quest_desc: ["Quando viene posizionato in un bioma del deserto, il nido di sabbia attirerà l'ape mineraria del cioccolato o della cenere."]
	quest.06044B4452A6B720.quest_subtitle: "Attira le api nei biomi del deserto"
	quest.065196033249A0AA.quest_subtitle: "Alloy Raw Biopolymer with an Iron Bee Egg"
	quest.065196033249A0AA.title: "Biosteel Bee"
