	quest.4FE7F45C72EF5DC1.title: "Nickel Bee"
	quest.500BEAD94C97DF96.quest_desc: ["Può essere posizionato in un'arnia o in una centrifuga.\\n\\nQuando è in un'arnia, diminuisce la quantità di tempo che le api trascorrono nell'alveare del 20%.\\n\\nQuando viene posizionato in una centrifuga, aumenta la velocità di elaborazione.\\n\\nQuesti elementi si accumulano."]
	quest.500BEAD94C97DF96.quest_subtitle: "Sonic Bees"
	quest.50ED69AEEE808B24.quest_subtitle: "Feed Liquid Lithium Bucket to a Water Bee"
	quest.50ED69AEEE808B24.title: "Lithium Bee"
