	quest.150FB369BEFFCBBF.title: "Lumium Bee"
	quest.15288215A4BA2596.quest_subtitle: "Feed a Rose Quartz Block to a Diamond Bee"
	quest.15288215A4BA2596.title: "Rose Quartz Bee"
	quest.1540A9CDE2ED77E8.quest_subtitle: "Prodotto con Energizer"
	quest.1540A9CDE2ED77E8.title: "Spirited Crystal Bee"
	quest.15C9CCCC8E06D430.quest_subtitle: "Feed a Black Quartz Block to a Crystalline Bee"
	quest.15C9CCCC8E06D430.title: "Black Quartz Bee"
	quest.160BD0185954C891.quest_desc: ["Invece di usare dolcetti al miele, questo alveare richiede lingotti d'oro per attirare le api."]
	quest.160BD0185954C891.quest_subtitle: "Attira un'ape dorata quando viene posizionata nello Nether"
	quest.16987C41D4F5BA47.quest_subtitle: "Prodotto con Alloy Smelter"
	quest.16987C41D4F5BA47.title: "Copper Alloy Bee"
	quest.170C31F3BAF050BC.quest_subtitle: "Made in Reprocessor"
	quest.170C31F3BAF050BC.title: "Blutonium Bee"
	quest.17419401147B5C02.quest_desc: [
		"Oltre ad attirare le api con i nidi, la maggior parte delle api richiede la creazione di &eBreeding&r o &9Conversion&r. (No, non è un errore di battitura.)"
		""
		"&eBee Breeding&r richiede 2 api e alimenti specifici che vengono dati loro per farle accoppiare."
		""
		"&9Bee Conversion&r richiede di nutrire un'ape con un oggetto specifico per convertirla in una nuova ape."
	]
	quest.17419401147B5C02.quest_subtitle: "The Bees and the Bees"
	quest.176ACC61DC206E55.quest_desc: ["Puoi trovare queste api nelle Crimson Forests. Il suo nido può anche essere ottenuto coltivando funghi cremisi, con una probabilità del 2%."]
	quest.176ACC61DC206E55.quest_subtitle: "Dai da mangiare a un Shroombee un fungo cremisi"
	quest.176ACC61DC206E55.title: "Crimson Shroombee"
	quest.177199FED92C3B5B.quest_subtitle: "Feed an Infused Diamond to a Diamond Bee"
	quest.177199FED92C3B5B.title: "Dimensional Bee"
	quest.17989643018D00C1.quest_desc: ["L'orticaria ti dà fastidio quando gocciola? Se è così, sei fortunato perché esiste una soluzione semplice.\\n\\nPuoi posizionare un &eSponge&r nello slot Bottiglia di un Alveare Avanzato per impedirgli di gocciolare."]
	quest.17989643018D00C1.quest_subtitle: "Non hai flebo"
	quest.17989643018D00C1.title: "Stopping Dripping"
	quest.17A322C3B309A4D4.quest_subtitle: "Sembra che alle api d'oro piacciano i dischi musicali"
	quest.17A322C3B309A4D4.title: "Regalium Bee"
	quest.17B18040EFA37F86.quest_subtitle: "Feed a Polonium Pellet to a Radioactive Bee"
	quest.17B18040EFA37F86.title: "Wasted Radioactive Bee"
