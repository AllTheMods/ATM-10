	task.5392CADA51B80879.title: "Vidro Tingido de Preto"
	task.6B580F95A2E5A465.title: "TodosOsDireitosReservados"
	task.6B84DAA99028ACEA.title: "Obsidianas"
	task.7F17E48ACE65C84E.title: "Modelos de Dados"
