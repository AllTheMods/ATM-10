{
	quest.00CB8D60E7831A57.quest_desc: ["As Catacumbas são estruturas subterrâneas massivas feitas de Tijolos de Pedras das Profundezas. Elas podem ter uma parte saindo do chão que você pode encontrar. \\n\\nDentro do enorme labirinto residem &7Esquecidos&r, Baús escondidos e o chefe: &aGuardião Esquecido&r. \\n\\nEspero que você esteja preparado para isso!"]
	quest.00CB8D60E7831A57.title: "Catacumbas"
	quest.01B13BBB41BBB460.quest_desc: ["A &cArmadura de Uthério&r tem os mesmos status que a Armadura de Netherita! \\n\\nSem precisar de um Molde de Ferraria!"]
	quest.01B13BBB41BBB460.title: "Armadura de &cUthério&r"
	quest.050D8480EE9D8E62.quest_desc: [
		"As Florestas de Wigglewood são florestas como todas as outras. \\n\\nSó que essas Árvores gostam de ir para onde bem entendem."
		"{image:atm:textures/questpics/undergarden/undergarden_wiggle.png width:200 height:100 align:center}"
	]
	quest.050D8480EE9D8E62.title: "Floresta de Wigglewood"
	quest.06D13E319C26C949.quest_desc: [
		"O Pântano de Cogumelos de Sangue é o lar dos gigantes Cogumelos de Sangue. \\n\\nSangue me deixa desconfortável, então acho que vou manter esta descrição curta."
		"{image:atm:textures/questpics/undergarden/undergarden_blood.png width:200 height:100 align:center}"
	]
	quest.06D13E319C26C949.title: "Pântano de Cogumelos de Sangue"
	quest.073BA8470EA37A00.quest_desc: [
		"Outro Mar, só que este é muito mais frio."
		"{image:atm:textures/questpics/undergarden/undergarden_icy.png width:200 height:100 align:center}"
	]
	quest.073BA8470EA37A00.title: "Mar Gelado"
	quest.08D9C809CF4062E8.quest_desc: ["Coma-os crus, asse-os, coloque-os em um Graveto. \\n\\nO que você não pode fazer com Underbeans!"]
	quest.0A0A991BAC99092C.quest_desc: [
		"O Pântano de Cogumelos Índigo é um Pântano muito mais preenchido do que o Pântano de Cogumelos de Sangue. \\n\\nClaro que tem Cogumelos Índigo, mas também Mini Árvores de Smogstem e lagoas de Virulent Mix. Eu me pergunto o que isso faz..."
		"{image:atm:textures/questpics/undergarden/undergarden_indigo.png width:200 height:100 align:center}"
	]
	quest.0A0A991BAC99092C.title: "Pântano de Cogumelos Índigo"
	quest.0A1D6E233C0ECC8E.quest_desc: [
		"&dNargoyles&r são criaturas nojentas e hostis que surgem no subsolo. \\n\\nEles têm 7 Corações e meio e tentarão te matar incansavelmente. \\n\\nEles não deixam cair nada e apenas servem como um obstáculo para aqueles que tentam minerar pacificamente. "
		"{image:atm:textures/questpics/undergarden/undergarden_nargoyle.png width:100 height:100 align:center}"
	]
	quest.0A1D6E233C0ECC8E.title: "&dNargoyle&r"
	quest.0C98503A2F20484D.quest_desc: [
		"Perto de Campo Gélido você pode encontrar Florestas de Smogstem Congeladas. \\n\\nElas são como Campo Gélido, mas com Árvores de Smogstem!"
		"{image:atm:textures/questpics/undergarden/undergarden_frostytrees.png width:200 height:100 align:center}"
	]
	quest.0C98503A2F20484D.title: "Floresta de Smogstem Congelada"
	quest.0D91A6B36BD2F526.quest_desc: ["Melhore seu &7Machado de Batalha de Cloggrum&r para fazer a melhor arma que o &2&lUndergarden&r pode dar!"]
	quest.0D91A6B36BD2F526.title: "Arma Ultimate!"
	quest.0FA77C28A57E06F1.quest_desc: ["Cogumelos Velados só podem ser encontrados em seu Pântano. \\n\\nEles têm Chapéus Marrons que, se houver Ar abaixo deles, gerarão Véus de Cogumelo. Daí o nome!"]
	quest.1054168AFD8520D4.quest_desc: [
		"O &aGuardião Esquecido&r é um Golem massivo feito de &aLingotes de Esquecidos&r. \\n\\nEle terá o Jogador como alvo e fará o que for preciso para matá-lo. \\n\\nEles têm 80 Corações e se você conseguir matá-los, eles deixarão cair &aPepitas de Esquecidos&r."
		"{image:atm:textures/questpics/undergarden/undergarden_guardian.png width:100 height:200 align:center}"
	]
	quest.1054168AFD8520D4.title: "&aGuardião Esquecido&r"
	quest.1190BB433EFA3945.quest_desc: ["O Estilingue é uma arma muito divertida adicionada pelo &2&lUndergarden&r. Tem 4 Munições que podem ser arremessadas: \\n\\nGosma de Scintling pode ser atirada e, quando atinge uma criatura, dá a ela o Efeito Pegajoso. \\n\\nPedras das Profundezas são apenas projéteis normais. \\n\\nFrutas Pustulentas Podres explodirão no impacto. \\n\\nE &eGronglets&r não causam nenhum dano, eles apenas fazem barulho e são atirados!"]
	quest.119242549BD21764.quest_desc: [
		"&eBrutes&r surgem em alguns Biomas e são Neutros. \\n\\nSe atingidos, todos na área atacarão você. Semelhante aos Lobos ou Piglins Zumbificados. \\n\\nAo morrerem, eles podem deixar cair suas Presas, que podem servir como um substituto para Ossos!"
		"{image:atm:textures/questpics/undergarden/undergarden_brute.png width:100 height:100 align:center}"
	]
	quest.119242549BD21764.title: "&eBrutes&r"
	quest.130577AD1A1A8222.quest_desc: ["&7Cloggrum&r tem status um pouco piores do que a Armadura de Ferro, mas praticamente cresce em Árvores, então acho que é justo. \\n\\nAs Botas também ajudam a atravessar a Gosma de Scintling!"]
	quest.130577AD1A1A8222.title: "Armadura de &7Cloggrum&r"
	quest.141681FE9E524FB0.quest_desc: [
		"&7Esquecidos&r são guerreiros que surgem dentro da Estrutura da Catacumba. \\n\\nEles usam Armadura Ancestral e seguram Ferramentas de Cloggrum, todas as quais podem ser deixadas cair ao morrerem. \\n\\nEles também atacarão e matarão as &cCriaturas Putrefatas&r."
		"{image:atm:textures/questpics/undergarden/undergarden_forgotten.png width:100 height:200 align:center}"
	]
	quest.141681FE9E524FB0.title: "&7Esquecido&r"
	quest.15A8F04BC10E619E.quest_desc: [
		"Algumas pessoas odeiam explorar muitos Biomas diferentes para obter todas as diferentes Mudas de Árvore. \\n\\nClaramente o desenvolvedor do &2&lUndergarden&r odiava, então ele colocou a maioria delas na Floresta Densa!"
		"{image:atm:textures/questpics/undergarden/undergarden_dense.png width:200 height:100 align:center}"
	]
	quest.15A8F04BC10E619E.title: "Floresta Densa"
	quest.16A04B2FC3F0D902.quest_desc: ["As Ferramentas de &7Cloggrum&r agem exatamente como Ferramentas de Ferro, só que estas se parecem mais com Lama do que o Ferro! \\n\\nA Espada causa mais dano do que uma Espada de Ferro, no entanto."]
	quest.16A04B2FC3F0D902.title: "Ferramentas de &7Cloggrum&r"
	quest.17C2C8F64B4AE6EE.quest_desc: [
		"&2Dwellers&r são as Vacas do &2&lUndergarden&r. \\n\\nEles são Pacíficos e deixarão cair Couro e Carne de Dweller ao morrerem. \\n\\nGraças a Deus eles não podem ser ordenhados, eu não quero nenhum leite que esses &2Dwellers&r produzem."
		"{image:atm:textures/questpics/undergarden/undergarden_dweller.png width:100 height:100 align:center}"
	]
	quest.17C2C8F64B4AE6EE.title: "&2Dweller&r"
	quest.19862DBCE9305DE3.quest_desc: ["A &3Lança&r, a arma de escolha dos &7Denizens&r... junto com o Machado de Madeira. \\n\\nVocê precisará de 2 Gravetos e &3Rogdorium&r para fabricá-la. \\n\\nEla tem o mesmo Dano que uma &bEspada de Diamante&r, além de um Alcance maior! \\n\\nEla também pode ser arremessada como um Tridente."]
	quest.19862DBCE9305DE3.title: "&3Lança"
	quest.1A23BBF444D17A63.quest_desc: [
		"&2Greater Dwellers&r surgem abaixo da Camada Y 0. Você precisará de uma &aPicareta de Esquecido&r ou &6Picareta de Allthemodium&r para minerar a Dreadrock no caminho. \\n\\n&2Greater Dwellers&r evoluíram de forma diferente dos membros menores de sua família, as Profundezas são perigosas, eles precisavam se tornar maiores e mais fortes! \\n\\nEles agora têm um tamanho maior com 100 Corações. Eles também serão Neutros em vez de Pacíficos. Como Piglins Zumbificados, se um for Atingido, todos Atacarão."
		"{image:atm:textures/questpics/undergarden/undergarden_greater.png width:100 height:100 align:center}"
	]
	quest.1A23BBF444D17A63.title: "&2Greater Dweller"
	quest.1BAE1519E44E40CE.quest_desc: [
		"Imagine o Mar Ancião. Ok, agora remova todas as Algas dele e remova todos os &bGwibs&r e &bGwiblings&r. \\n\\nEsse é o Mar Morto para você!"
		"{image:atm:textures/questpics/undergarden/undergarden_dead.png width:200 height:100 align:center}"
	]
	quest.1BAE1519E44E40CE.title: "Mar Morto"
	quest.1C232674CD04024D.quest_desc: ["A Dimensão do &2&lUndergarden&r está cheia de Biomas diversos e nojentos, cheios de muita Vegetação, Criaturas: amigáveis e não amigáveis, e claro, Minérios e Itens. \\n\\nEspero que você esteja pronto para uma luta!"]
	quest.1C232674CD04024D.title: "Bem-vindo ao &2&lUndergarden&r!"
	quest.1D2C70F1750E84D0.quest_desc: [
		"Uma nova Criatura &cPutrefatas&r? \\n\\nO &cRotbelcher&r tem 17 Corações e meio e 4 Pontos de Armadura. \\n\\nSe estiverem perto de você, eles balançarão os Braços na sua direção. Se você estiver um pouco mais longe, eles cuspirão em você. \\n\\nEles precisam de um enxaguante bucal se o cuspe deles é tão nojento."
		"{image:atm:textures/questpics/undergarden/undergarden_rotbelcher.png width:100 height:200 align:center}"
	]
	quest.1D2C70F1750E84D0.title: "&cRotbelcher"
	quest.1E13D7CE5A9EFF74.quest_desc: [
		"Campo Gélido são um dos Biomas frios no &2&lUndergarden&r. Você pode perceber que é frio pelos enormes pingentes de gelo, Neve em Pó e Deepturf Congelado! \\n\\nAlém disso, aqui, em vez do subsolo de Pedras das Profundezas usual, você encontrará Shiverstone. \\n\\nShiverstone age mais como Gelo do que Pedra real. Bem, pelo menos ao ficar de pé sobre ele!"
		"{image:atm:textures/questpics/undergarden/undergarden_frosty.png width:200 height:100 align:center}"
	]
	quest.1E13D7CE5A9EFF74.title: "Campo Gélido"
	quest.1E81B903137BB62A.quest_desc: ["Ferramentas Normais simplesmente não serão suficientes, especialmente ao lidar com as perigosas Criaturas no &2&lUndergarden&r. \\n\\nNós podemos fabricar o &7Escudo de Cloggrum&r, que age como um Escudo normal. \\n\\nMas precisaremos obter o &7Machado de Batalha&r como uma recompensa rara dos &7Esquecidos&r."]
	quest.1E81B903137BB62A.title: "Armas de &7Cloggrum&r"
	quest.1FCF946B7BE3C0BD.quest_desc: ["Ferramentas de &cUthério&r são semelhantes às Ferramentas de Diamante, mas as armas são mais eficazes contra as &cCriaturas Putrefatas&r! \\n\\nVocê usa o que elas fazem para causar mais dano a elas! Provavelmente há uma dúzia de referências da cultura pop que eu posso fazer com isso, mas não consigo pensar em nenhuma..."]
	quest.1FCF946B7BE3C0BD.title: "Ferramentas de &cUthério&r"
	quest.22739522F0D33D7B.quest_desc: ["Gloomgourds surgem e são cultivadas como Abóboras. \\n\\nAssim como as Abóboras, elas podem ser transformadas em Torta ou até mesmo em Jack-O-Lanterns! \\n\\nAo contrário das Abóboras, elas podem ser transformadas em explosivos..."]
	quest.24D38DA8E86DD897.quest_desc: [
		"A menor e mais fraca das &cCriaturas Putrefatas&r. \\n\\nEstes têm 5 Corações. \\n\\nComo todas as &cCriaturas Putrefatas&r, eles atacarão &2Stoneborns&r e &7Esquecidos&r e deixarão cair &cFragmentos de Uthério&r."
		"{image:atm:textures/questpics/undergarden/undergarden_rotling.png width:100 height:100 align:center}"
	]
	quest.24D38DA8E86DD897.title: "&cRotling&r"
	quest.257893DD23BF5017.quest_desc: ["Para obter &3Rogdorium&r precisaremos visitar as Profundezas abaixo da Camada Y 0. Para isso, você precisará de uma &aPicareta de Esquecidos&r ou &6Picareta de Allthemodium&r. \\n\\nVocê também precisará da Picareta do mesmo Nível para minerar &3Minério de Rogdorium&r. Ele surge em qualquer lugar nas Profundezas. \\n\\nVocê também pode usar um &aMachado de Esquecido&r ou de &6Allthemodium&r para minerar uma &3Raiz Ancestral de Rogdoric&r. Estas são muito mais comuns, mas só darão uma &3Pepita de Rogdorium&r em comparação com a versão completa que o &3Minério&r fornece."]
	quest.257893DD23BF5017.title: "&3Rogdorium"
	quest.278D34BBC13356DF.quest_desc: [
		"Um Pântano roxo! \\n\\nEstes têm Cogumelos de Tinta e Virulent Mix por toda parte!"
		"{image:atm:textures/questpics/undergarden/undergarden_ink.png width:200 height:100 align:center}"
	]
	quest.278D34BBC13356DF.title: "Pântano de Cogumelos de Tinta"
	quest.2A2041098C069772.quest_desc: [
		"&7Denizens&r surgem nas Profundezas, que ficam abaixo da Camada Y 0. Você precisará de uma &aPicareta de Esquecido&r ou um Nível semelhante para minerar lá embaixo. \\n\\nOs &7Denizens&r parecem estranha e grosseiramente humanos, eles usam Máscaras Misteriosas e segurarão uma Lança ou um Machado de Madeira. \\n\\nOs &7Denizens&r vêm em tamanhos baixos e redondos ou altos e magros. Mas todos eles têm 10 Corações. \\n\\nEles não deixam cair nada, exceto talvez sua Arma."
		"{image:atm:textures/questpics/undergarden/undergarden_denizens.png width:100 height:200 align:center}"
	]
	quest.2A2041098C069772.title: "&7Denizen"
	quest.2C5A7E4CD8B57E08.quest_desc: ["Árvores de Grongle são árvores altas parecidas com as da Selva que só surgem em Biomas Gronglegrowth! \\n\\nEssas Árvores também são onde os &eGronglets&r surgem."]
	quest.2E596B5A4EA2ABF4.quest_desc: [
		"Aquela pedra está se movendo? Não, espere, é apenas um &3S'Mog&r! O primo próximo do &2Mog&r! \\n\\nEles agem exatamente como os &2Mogs&r, só que estes podem deixar cair Musgo-Mog Azul."
		"{image:atm:textures/questpics/undergarden/undergarden_smog.png width:100 height:100 align:center}"
	]
	quest.2E596B5A4EA2ABF4.title: "&3S'Mog&r"
	quest.30582B5FBED35FD1.quest_desc: ["&cAgregados de Uthério&r e &cFragmentos&r podem ser deixados por várias Criaturas diferentes, especialmente os Monstros &cPutrefatas&r. \\n\\n9 &cFragmentos&r fazem 1 &cAgregado&r. \\n\\nNós então precisaremos usar um Infusor para combinar &3Rogdorium&r e um &cAgregado de Uthério&r para fabricar um &cCristal de Uthério&r."]
	quest.30582B5FBED35FD1.title: "&cUthério&r"
	quest.30D6924003C6E273.quest_desc: ["Acampamentos de &7Denizens&r podem ser encontrados nas Profundezas. Você precisará minerar abaixo da Camada Y 0, passando pela Dreadrock. \\n\\nDreadrock precisa de uma &aPicareta de Esquecido&r para ser minerada. Esse é o mesmo Nível que a &6Picareta de Allthemodium&r. \\n\\nAqui um bando de &7Denizens&r surgirá, além de Totens Misteriosos e Baús! Raramente um Baú pode gerar uma Máscara Misteriosa, a mesma que os &7Denizens&r usam. \\n\\nUsar uma Máscara Misteriosa perto dos &7Denizens&r é como usar &eOuro&r na frente dos Piglins. Eles serão Neutros a menos que alguém seja atingido (ou algo seja feito para agravá-los)."]
	quest.30ED5FF9DF7B34CF.quest_desc: ["Seja saqueando um Acampamento de Denizen ou fabricando isso, nós podemos usar o Totem Misterioso! \\n\\nUhhh... como usamos isso? \\n\\nSimplesmente coloque-o no chão e a cada par de Segundos ele lhe dará &bPureza&r por 10 Segundos. \\n\\nA &bPureza&r limpará você da &cPutrefação&r."]
	quest.353AEEC116A5DEEF.quest_desc: [
		"Os Mares Anciões são Mares bem abertos no &2&lUndergarden&r. \\n\\nDe alguma forma, mesmo com a quantidade de poluentes, a Água é segura para beber. \\n\\nA Água também abriga &bGwibs&r e &bGwiblings&r. E não podemos esquecer as Glitterkelp!"
		"{image:atm:textures/questpics/undergarden/undergarden_ancient.png width:200 height:100 align:center}"
	]
	quest.353AEEC116A5DEEF.title: "Mar Ancião"
	quest.36389696767EFB4E.quest_desc: [
		"O Abismo Árido é, como o nome sugere, árido... Ele não contém nada além de Criaturas Hostis e Seixos. \\n\\nPessoalmente, eu preferiria encontrar Seixos em qualquer outro lugar..."
		"{image:atm:textures/questpics/undergarden/undergarden_barren.png width:200 height:100 align:center}"
	]
	quest.36389696767EFB4E.title: "Abismo Árido"
	quest.380D3212D1CBA593.quest_desc: [
		"A &cCriatura Putrefata&r de tamanho médio, o &cRotwalker&r. \\n\\nEles têm 20 Corações. \\n\\nComo todas as &cCriaturas Putrefatas&r, eles atacarão &2Stoneborns&r e &7Esquecidos&r e deixarão cair &cFragmentos de Uthério&r."
		"{image:atm:textures/questpics/undergarden/undergarden_rotwalker.png width:100 height:200 align:center}"
	]
	quest.380D3212D1CBA593.title: "&cRotwalker&r"
	quest.3AF7446592D19FA6.quest_desc: ["&eRegalium&r é o equivalente à Esmeralda no &2&lUndergarden&r. \\n\\nNão pode ser transformado em Armadura ou Ferramentas, mas pode ser usado para trocar com &2Stoneborns&r por outros Itens."]
	quest.3AF7446592D19FA6.title: "&eRegalium&r"
	quest.4141EF8B8C316118.quest_desc: ["&7Cloggrum&r é o Ferro do &2&lUndergarden&r. \\n\\nEle é encontrado em todo lugar e é usado em dezenas de receitas diferentes. \\n\\nCaramba, até algumas Criaturas o deixam cair!"]
	quest.4141EF8B8C316118.title: "&7Cloggrum&r"
	quest.43A1BC20BB054A14.quest_desc: ["Glitterkelp cresce em Mares Anciões e Gelados. \\n\\nElas não fazem muito além de Brilhar e podem ser fabricadas em Torta!"]
	quest.43FD4AEBB9548E57.quest_desc: [
		"A Floresta de Smogstem é um Bioma vizinho aos Pântanos de Cogumelos Índigo. \\n\\nClaro que também é Azul e tem Cogumelos Índigo! Apenas tem Árvores de Smogstem maiores!"
		"{image:atm:textures/questpics/undergarden/undergarden_smogstem.png width:200 height:100 align:center}"
	]
	quest.43FD4AEBB9548E57.title: "Floresta de Smogstem"
	quest.4568C2F465EDB960.quest_desc: ["Droopfruit pode surgir em quase qualquer Bioma, basta olhar para cima! \\n\\nElas surgem no teto da maioria dos Biomas e crescerão de forma semelhante às Glowberries."]
	quest.46DCB235D3FEDA61.quest_desc: ["Semelhante às Ferramentas de Ferro, só que todas essas desaceleram quem for atingido por elas. \\n\\nBem, exceto a Enxada, mas você realmente se importa com uma simples enxada?"]
	quest.46DCB235D3FEDA61.title: "Ferramentas de &bAço Gelado&r"
	quest.4985F82E0D300C6D.quest_desc: ["Se você quer ir para casa na &2&lSuperfície&r, mas não consegue encontrar o seu Portal original, não se preocupe, existe um jeito! \\n\\nCom 4 Pedras das Profundezas, 4 &7Lingotes de Cloggrum&r e uma &aPepita de Esquecido&r, você pode fabricar o Crumbling Catalyst. \\n\\nO Crumbling Catalyst funciona exatamente como o Catalyst normal na ativação de um Portal. "]
	quest.49EB9FB2133E3219.quest_desc: ["Armadura Ancestral é o que os &7Esquecidos&r usam, e é de onde você pode obtê-la. \\n\\nNão há Botas Ancestrais, entretanto, aparentemente os &7Esquecidos&r não têm pés."]
	quest.49EB9FB2133E3219.title: "Armadura Ancestral"
	quest.4C5CFA45D9B4F6D3.quest_desc: ["Cogumelos Índigo são aparentemente os melhores amigos das Smogstems e surgirão principalmente com elas! "]
	quest.4C7E006502E30C20.quest_desc: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2Contribuinte da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r estão licenciados sob &eTodos os Direitos Reservados&r, esta Missão não tem permissão para ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, você está no modo de edição."]
	quest.4D836B9D9E3B898F.quest_desc: [
		"Os &aStoneborns&r são a mistura perfeita de Aldeões e Golems de Ferro. \\n\\nVocê pode trocar com eles clicando com o Botão Direito neles. \\n\\nE eles lutarão contra Criaturas Hostis (ou Jogadores que os atingirem)."
		"{image:atm:textures/questpics/undergarden/undergarden_stoneborn.png width:100 height:150 align:center}"
	]
	quest.4D836B9D9E3B898F.title: "&aStoneborn&r"
	quest.4E3D548E5D8D7D26.quest_desc: [
		"Os Campos de Esquecidos são as Planícies do &2&lUndergarden&r. \\n\\nEles não têm Árvores, mas têm muitas Pedras, Flores e Criaturas! \\n\\nNo entanto, eles não geram &7Esquecidos&r, é, desculpe estragar seu entusiasmo."
		"{image:atm:textures/questpics/undergarden/undergarden_field.png width:200 height:100 align:center}"
	]
	quest.4E3D548E5D8D7D26.title: "Campos de Esquecido"
	quest.4F3B4990BE6C2A4A.quest_desc: [
		"Os &7Scintlings&r são pequenas e inocentes Lesmas encontradas em todos os lugares do &2&lUndergarden&r. \\n\\nEles agem como Golems de Neve, pois deixam um rastro por onde andam. Só que este é mais Pegajoso... \\n\\nAo morrerem, eles deixam cair Gosma de Scintling, mas você pode simplesmente farmá-la de seus rastros, então por que matá-los!"
		"{image:atm:textures/questpics/undergarden/undergarden_scintling.png width:150 height:100 align:center}"
	]
	quest.4F3B4990BE6C2A4A.title: "&7Scintling&r"
	quest.4F5A2E2A5C7F4837.quest_desc: ["&aLingotes de Esquecido&r precisam ser obtidos através das Catacumbas; seja saqueando os Baús ou matando o &aGuardião Esquecido&r. \\n\\nVocê também precisará de um Molde de Ferraria, que é encontrado nos Baús da Catacumba."]
	quest.4F5A2E2A5C7F4837.title: "&aEsquecido&r"
	quest.511144EF336BFAF5.quest_desc: [
		"As Torres de Poluição são... sim, você adivinhou! De onde vem todo o Smog! Bem, não todo, não podemos desacreditar os &2Mogs&r e &3S'mogs&r. \\n\\nAqui você encontrará Frutas Pustulentas, Coarse Deepsoil e Smog Vents. Eu não recomendaria chegar perto deles, no entanto..."
		"{image:atm:textures/questpics/undergarden/undergarden_smogspires.png width:200 height:100 align:center}"
	]
	quest.511144EF336BFAF5.title: "Torres de Poluição"
	quest.51C59FDF0BD11FDF.quest_desc: ["Tenho quase certeza de que a única definição do que é uma Árvore de Wigglewood é que ela tem Troncos e Folhas de Wigglewood. Elas parecem crescer em qualquer direção, tamanho e formato. \\n\\nVocê pode encontrá-las em Florestas de Wigglewood e Florestas Densas. \\n\\nElas têm lindas Folhas rosas e Troncos marrons semelhantes ao Abeto!"]
	quest.51E2728C5E35A152.quest_desc: ["Aço Gelado surge nos Biomas Congelados: Campo Gélido, Florestas de Smogstem Congeladas e provavelmente Mares Gelados. \\n\\nEle surge na Shiverstone, que substitui a Pedras das Profundezas nestes Biomas. A Shiverstone agirá de forma semelhante ao Gelo, pois é escorregadia e te desacelera um pouco. \\n\\nVocê também pode encontrar algumas Pepitas nas barrigas dos Munchers!"]
	quest.51E2728C5E35A152.title: "&bAço Gelado&r"
	quest.53FDC6C536E50A1A.quest_desc: ["Os &bGwiblings&r são peixes amigáveis nos Mares. \\n\\nEles são menores que os &bGwibs&r e agem como Peixes do &2&lVanilla&r!"]
	quest.53FDC6C536E50A1A.title: "&bGwibling&r"
	quest.57545837046F552B.quest_desc: [
		"Espere, isso não é um Pote normal! \\n\\n&2Potes Misteriosos&r são criaturas vivas que se disfarçam de Potes. \\n\\nEles têm 4 Corações e fugirão de você quando Atingidos. Se acharem que estão a salvo de você, eles retornarão ao seu disfarce. \\n\\nAo Morrerem, eles podem Deixar Cair &7Cloggrum&r, &bPepitas de Aço Gelado&r e &cFragmentos de Uthério&r. "
		"{image:atm:textures/questpics/undergarden/undergarden_pot.png width:100 height:120 align:center}"
	]
	quest.57545837046F552B.title: "&2Potes Misteriosos"
	quest.5AF0E903DB670D65.quest_desc: ["Com um pouco de Dreadrock, &3Rogdorium&r e um &cAgregado de Uthério&r, nós podemos fazer o Infusor! \\n\\nEste é um Bloco que podemos usar para Fabricar e Infundir certos Itens. No momento, não há muitas Receitas, mas aposto que veremos mais! \\n\\nO uso principal será Fabricar &cCristais de Uthério&r e Infundir Armaduras com &3Rogdorium&r. \\n\\nSe a Armadura for Infundida com &3Rogdorium&r, ela o protegerá de pegar a doença do &cRot&r. "]
	quest.5B4B5C148D63ACA1.quest_desc: [
		"&aServos Esquecidos&r não surgem como Criaturas normais, eles precisam ser criados. Eles são criados colocando uma Gloomgourd Entalhada sobre um &aBloco de Lingotes de Esquecido&r. \\n\\nEles agem de forma semelhante aos Golems de Neve, eles nunca atacarão você, e em vez disso, atirarão em Criaturas Hostis. \\n\\nEles têm 10 Corações e não deixam cair nada ao morrerem... mas tipo, por que você os mataria?"
		"{image:atm:textures/questpics/undergarden/undergarden_minion.png width:125 height:100 align:center}"
	]
	quest.5B4B5C148D63ACA1.title: "&aServos Esquecidos&r"
	quest.5D229FA3A5F92954.quest_desc: [
		"Os &4Munchers&r são semelhantes a quaisquer outras Criaturas Hostis no &2&lUndergarden&r, mas os itens que este deixa cair o tornam muito mais útil! \\n\\nO Muncher pode deixar cair &7Cloggrum&r e &bPepitas de Aço Gelado&r ao morrer."
		"{image:atm:textures/questpics/undergarden/undergarden_muncher.png width:100 height:100 align:center}"
	]
	quest.5D229FA3A5F92954.title: "&4Muncher&r"
	quest.5E63C78CDC44FF95.quest_desc: ["Frutas Pustulentas Podres não podem ser arremessadas, mas quando transformadas em Blisterbombs, elas podem ser! \\n\\nVocê pode até ir mais longe e fazer Boomgourds, que agirão como TNT que joga Frutas Pustulentas para todo lado."]
	quest.5E63C78CDC44FF95.title: "Explosivos!!!"
	quest.5FCA6F5FE97780B7.quest_desc: [
		"Os &eGronglets&r são tecnicamente Blocos, não Criaturas. Mas eu os amo demais para não incluí-los! \\n\\nEles surgem nas Árvores de Grongle e emitem Barulho e Luz! Definitivamente perfeitos para decoração."
		"{image:atm:textures/questpics/undergarden/undergarden_gronglet.png width:100 height:100 align:center}"
	]
	quest.5FCA6F5FE97780B7.title: "&eGronglets&r"
	quest.6124C0E9E419694B.quest_desc: ["Melhore as Ferramentas de &7Cloggrum&r com &aLingotes de Esquecido&r e um Molde de Ferraria. \\n\\nEstas são as melhores Ferramentas que você pode obter, elas já vêm com Eficiência apenas para Blocos do &2&lUndergarden&r. \\n\\nE a Espada e o Machado causarão mais dano a todas as Criaturas do &2&lUndergarden&r, exceto a &cRotbeast&r e o &aGuardião Esquecido&r!"]
	quest.6124C0E9E419694B.title: "Ferramentas do &aEsquecido&r"
	quest.647A87E800C703C3.quest_desc: [
		"Meu Bioma favorito de longe! \\n\\nUma Selva Verde gigante com enormes Árvores de Gronglegrowth. \\n\\nNessas Árvores você pode encontrar &eGronglets&r!"
		"{image:atm:textures/questpics/undergarden/undergarden_grongle.png width:200 height:100 align:center}"
	]
	quest.647A87E800C703C3.title: "Gronglegrowth"
	quest.6751F2651063B3A5.quest_desc: ["Cogumelos de Sangue podem ser encontrados em seus Pântanos. \\n\\nEles têm a forma de Árvores de Carvalho Escuro e são em sua maioria Brancos, com apenas alguns blocos tendo manchas de Sangue neles!"]
	quest.67A2347534269528.quest_desc: [
		"Os &9Sploogies&r raramente podem surgir, mas quando surgem, estão destinados a irritar você. \\n\\nEles atirarão cuspe em você (e farão ruídos de sucção nojentos), mas se você os atingir, eles fugirão; semelhante a um filhote de Piglin. \\n\\nEles deixam cair apenas Seixos de Pedras das Profundezas ao morrer."
		"{image:atm:textures/questpics/undergarden/undergarden_sploogie.png width:125 height:100 align:center}"
	]
	quest.67A2347534269528.title: "&9Sploogie&r"
	quest.6C4B93FE64BD418D.quest_desc: ["Chegar ao &2&lUndergarden&r é semelhante a chegar ao &c&lNether&r. Você precisará fabricar um Portal. \\n\\nTem a mesma forma e tamanho dos Portais do Nether, mas em vez de Obsidiana, você precisará de uma variante de Tijolos de Pedra. Tijolos de Pedra, Tijolos de Pedra Musgosa ou Tijolos de Ardosiabissal. \\n\\nUma vez formado, você pode ativá-lo usando o Catalyst nele. "]
	quest.6C4B93FE64BD418D.quest_subtitle: "Fazendo o Portal"
	quest.6C4B93FE64BD418D.title: "O Undergarden"
	quest.6D4FB6291CA8D1A6.quest_desc: ["As Árvores de Smogstem são muito mais grossas em suas metades inferiores, semelhantes aos Baobás na vida real! \\n\\nElas têm Folhas Azuis com Troncos Cinzas. \\nVocê pode encontrá-las em vários Biomas: Florestas de Smogstem, Florestas Densas e até mesmo em Pântanos de Cogumelos Índigo!"]
	quest.6E7C8537D8A28833.quest_desc: [
		"Abaixo da Camada Y 0 há dois Biomas, as Profundezas é um deles. \\n\\nPara chegar abaixo da Camada Y 0, você precisará minerar Dreadrock. Para minerar Dreadrock, você precisará de uma Picareta de Esquecido ou Picareta de Allthemodium. \\n\\nAqui surgirão Greater Dwellers, Denizens e Monstros Rot."
		"{image:atm:textures/questpics/undergarden/undergarden_depths.png width:200 height:100 align:center}"
	]
	quest.6E7C8537D8A28833.title: "Profundezas"
	quest.6F416275B6F6D8F0.quest_desc: ["Frutas Pustulentas surgem nas Torres de Poluição. \\n\\nPorque elas crescem em uma área tão nojenta, algumas virão Podres. \\n\\nEu não recomendo comê-las, talvez elas possam ser úteis para outra coisa!"]
	quest.6F483B77D64F4EE2.quest_desc: [
		"Abaixo da Camada Y 0 há dois Biomas, o Bosque de Rogdorium é um deles. \\n\\nPara chegar abaixo da Camada Y 0, você precisará minerar Dreadrock. Para minerar Dreadrock, você precisará de uma Picareta de Esquecido ou Picareta de Allthemodium. \\n\\nUm Bioma muito mais agradável em comparação com as Profundezas. Muito menos Monstros e muito mais vida vegetal! Agora com Árvores de Smogstem e muitas Flores."
		"{image:atm:textures/questpics/undergarden/undergarden_rogdorium.png width:200 height:100 align:center}"
	]
	quest.6F483B77D64F4EE2.title: "Bosque de Rogdorium"
	quest.70FD8856BFCD9AEE.quest_desc: [
		"A maior e mais perigosa &cCriatura Putrefata&r. \\n\\nEles têm 80 Corações, o que eu acho que se qualifica como um Chefe. \\n\\nComo todas as &cCriaturas Putrefatas&r, eles atacarão &2Stoneborns&r e &7Esquecidos&r e deixarão cair &cFragmentos de Uthério&r."
		"{image:atm:textures/questpics/undergarden/undergarden_rotbeast.png width:100 height:100 align:center}"
	]
	quest.70FD8856BFCD9AEE.title: "&cRotbeast&r"
	quest.71E1454990DEC451.quest_desc: [
		"Os &bGwibs&r são versões maiores e mais irritadas dos &bGwiblings&r. \\n\\nEles não deixam cair nada, nem podem ser colocados em Baldes. Tudo o que eles oferecem é dor!"
		"{image:atm:textures/questpics/undergarden/undergarden_gwib.png width:100 height:100 align:center}"
	]
	quest.71E1454990DEC451.title: "&bGwib&r"
	quest.739601B0C43B239B.quest_desc: ["Sim, eles podem fazer Corante Preto!"]
	quest.744DBE831C120B2F.quest_desc: [
		"Aquela pedra está se movendo? Ah, espere, não é uma pedra, é um &aMog&r! \\n\\nOs &aMogs&r podem ser procriados com Seixos de Pedras das Profundezas e, ao morrerem, podem deixar cair mais Seixos ou Musgo-Mog! \\n\\nMusgo-Mog pode ser usado em muitas receitas diferentes!"
		"{image:atm:textures/questpics/undergarden/undergarden_mog.png width:100 height:100 align:center}"
	]
	quest.744DBE831C120B2F.title: "&aMog&r"
	quest.75A66B81C1181F59.quest_desc: ["Vestígios de Esquecidos são pequenas ruínas de Tijolos de Pedras das Profundezas encontradas dentro do &2&lUndergarden&r. \\n\\nAqui há muitos Potes cheios de Saques! \\n\\nApenas quebre-os!"]
	quest.75A66B81C1181F59.title: "Vestígio de Esquecido"
	quest.7617737FC179EA1A.quest_desc: ["A Armadura de &bAço Gelado&r é ligeiramente pior que a Armadura de Diamante, mas também oferece grande Resistência à Repulsão. \\n\\nEla também dá penalidade de Velocidade, no entanto, parece que não vamos nos mover muito!"]
	quest.7617737FC179EA1A.title: "Armadura de &bAço Gelado&r"
	quest.76CDC18D7A208512.quest_desc: ["No &2&lUndergarden&r, as &cCriaturas Putrefatas&r: &cRotling&f, &cRotwalker&f, &cRotbelcher&f e a &cRotbeast&r podem infectá-lo com &cUthério&r. \\n\\nIsso aparecerá como Barras Vermelhas acima das suas Barras de Fome se você pegar. Após 4 Barras cheias, linhas vermelhas aparecerão na sua tela. Em 8 Barras, as Barras começarão a tremer para avisá-lo de que está piorando. Em 10 Barras, todas elas brilharão e é quando você começa a receber Dano. \\n\\nA &cPutrefação&r desaparecerá lentamente sozinho, a menos que esteja cheio. Você também pode obter Pureza de Totens Misteriosos ou Comer &3Rogdorium&r para se livrar dele. \\n\\nAmbos vêm das Profundezas, que Surgem abaixo da Camada Y 0. Você precisará de uma &aPicareta de Esquecido&r ou outra Picareta do mesmo Nível, como a de &6Allthemodium&r, para alcançá-la. \\n\\nA única maneira de prevenir a &cPutrefação&r é Infundindo sua Armadura com &3Rogdorium&r usando o Infusor."]
	quest.76CDC18D7A208512.title: "Aviso"
	quest.79C652E3FCB88550.quest_desc: [
		"Os &5Gloompers&r são tecnicamente Pacíficos, mas eles têm um mecanismo de defesa contra você, então eu os considero Neutros! \\n\\nQuando atingidos, eles soltarão um Efeito semelhante a uma Poção Prolongada. \\n\\nAo morrerem, eles deixarão cair suas Pernas (que são muito saborosas) e possivelmente Couro. \\n\\nEles também podem ser procriados com Gloomgourds!"
		"{image:atm:textures/questpics/undergarden/undergarden_gloomper.png width:100 height:100 align:center}"
	]
	quest.79C652E3FCB88550.title: "&5Gloomper&r"
	quest.7E3DA4168D352B42.quest_desc: [
		"Eu prometo que este é o último Pântano de Cogumelos! \\nEsses Cogumelos parecem bem normais, o truque deles, no entanto, é o que vem deles! \\n\\nOs Véus! Definitivamente um Bloco de decoração útil."
		"{image:atm:textures/questpics/undergarden/undergarden_veil.png width:200 height:100 align:center}"
	]
	quest.7E3DA4168D352B42.title: "Pântano de Cogumelos de Véu"
	task.39194D9CDF673768.title: "TodosOsDireitosReservados"
	task.4AA225E5056787B8.title: "TodosOsDireitosReservados"
}